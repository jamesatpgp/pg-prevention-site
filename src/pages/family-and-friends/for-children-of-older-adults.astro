---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HelpCallout from "../../components/HelpCallout.astro";
---

<BaseLayout
  title="For children of older adults"
  description="Gambling-harm support and information for the adult children of older adults."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">
        <a href="/family-and-friends">← Family &amp; friends</a>
      </p>
      <h1>For children of older adults</h1>
      <p class="page-header__lead">
        Support and information for adult children who are concerned about an
        aging parent's gambling.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container prose">
      <p>Resources for this audience are being developed. <em>[Content coming soon.]</em></p>
      <HelpCallout />
    </div>
  </section>
</BaseLayout>
