---
import BaseLayout from "../layouts/BaseLayout.astro";

const topics = [
  {
    title: "Strategic Prevention Framework",
    body: "SAMHSA's five-step planning process — assessment, capacity, planning, implementation, evaluation — applied to gambling.",
    href: "/understand-prevention/strategic-prevention-framework",
  },
  {
    title: "Strategies",
    body: "The six CSAP prevention strategies and the IOM intervention spectrum — the menu of work prevention professionals do.",
    href: "/understand-prevention/strategies",
  },
  {
    title: "Coalitions",
    body: "Community coalitions, the 12-sector model, CADCA's Seven Strategies, and the industry-funding tension distinctive to gambling.",
    href: "/understand-prevention/coalitions",
  },
  {
    title: "Comorbidities",
    body: "Substance use, mood, anxiety, ADHD, trauma, and suicide risk — and why integrated prevention reaches gambling too.",
    href: "/understand-prevention/comorbidities",
  },
];
---

<BaseLayout
  title="Understand Prevention"
  description="Plain-language information about problem gambling prevention — what it is, how it works, and who does the work."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Public education</p>
      <h1>Understand prevention</h1>
      <p class="page-header__lead">
        Clear, practitioner-oriented information about problem gambling
        prevention — the planning framework, the strategy menu, the coalition
        model, and the conditions that travel with gambling.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          topics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
