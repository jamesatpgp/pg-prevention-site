---
import BaseLayout from "../layouts/BaseLayout.astro";

const audiences = [
  { title: "Prevention Specialists", body: "Resources for credentialed prevention specialists working in problem gambling prevention.", href: "/professionals/prevention-specialists" },
  { title: "Treatment Providers", body: "Screening, referral, and prevention resources for treatment providers.", href: "/professionals/treatment-providers" },
  { title: "Healthcare Providers", body: "Brief screening and referral for doctors, dentists, and other clinicians.", href: "/professionals/healthcare-providers" },
  { title: "Teachers", body: "Classroom-ready awareness and prevention resources for educators.", href: "/professionals/teachers" },
];
---

<BaseLayout
  title="Professionals"
  description="Problem gambling prevention resources organized by profession — prevention specialists, treatment providers, healthcare providers, and teachers."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Resources by profession</p>
      <h1>Professionals</h1>
      <p class="page-header__lead">
        Problem gambling prevention resources, organized by the profession
        they're for.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          audiences.map((a) => (
            <li>
              <a class="card-link" href={a.href}>
                <span class="card-link__title">{a.title}</span>
                <span>{a.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p style="margin-top: var(--space-6); font-weight: 700;">
        <a href="/resources">Browse the Resource Library →</a>
      </p>
    </div>
  </section>
</BaseLayout>
