---
import { jurisdictions, linkFor } from "../data/map-jurisdictions";

// Pointy-top hex tile grid, projected at build time. No runtime JS.
const size = 24;
const dx = Math.sqrt(3) * size;
const dy = 1.5 * size;
const pad = size + 2;

const placed = jurisdictions.map((j) => ({
  ...j,
  cx: pad + j.hex.col * dx + (j.hex.row % 2) * (dx / 2),
  cy: pad + j.hex.row * dy,
}));

const vbW = Math.max(...placed.map((p) => p.cx)) + dx;
const vbH = Math.max(...placed.map((p) => p.cy)) + dy + 4;

function hexPoints(cx: number, cy: number): string {
  const pts: string[] = [];
  for (let i = 0; i < 6; i++) {
    const a = (Math.PI / 180) * (60 * i - 90);
    pts.push(`${(cx + size * Math.cos(a)).toFixed(1)},${(cy + size * Math.sin(a)).toFixed(1)}`);
  }
  return pts.join(" ");
}

// Territory caption divider
const terrTop = Math.min(...placed.filter((p) => p.type === "territory").map((p) => p.cy));
const dividerY = terrTop - dy / 2 - 6;
---

<svg
  class="us-hex-map"
  viewBox={`0 0 ${vbW.toFixed(0)} ${vbH.toFixed(0)}`}
  role="group"
  aria-label="U.S. states and territories — select one for local resources"
  xmlns="http://www.w3.org/2000/svg"
>
  <line class="hex-divider" x1="2" y1={dividerY.toFixed(0)} x2={(vbW - 2).toFixed(0)} y2={dividerY.toFixed(0)} />
  <text class="hex-caption" x="2" y={(dividerY - 6).toFixed(0)}>U.S. Territories below</text>
  {
    placed.map((p) => (
      <a href={linkFor(p)} aria-label={p.name}>
        <title>{p.name}</title>
        <polygon class="hex" points={hexPoints(p.cx, p.cy)} />
        <text class="hex-label" x={p.cx.toFixed(1)} y={p.cy.toFixed(1)} aria-hidden="true">
          {p.code}
        </text>
      </a>
    ))
  }
</svg>

<style>
  .us-hex-map {
    display: block;
    width: 100%;
    height: auto;
  }
  .hex {
    fill: var(--c-primary-tint);
    stroke: var(--c-primary);
    stroke-width: 1.5;
    transition: fill 0.15s ease;
  }
  .hex-label {
    fill: var(--c-heading);
    font-size: 15px;
    font-weight: 800;
    text-anchor: middle;
    dominant-baseline: central;
    pointer-events: none;
  }
  .us-hex-map a {
    cursor: pointer;
  }
  .us-hex-map a:hover .hex,
  .us-hex-map a:focus-visible .hex {
    fill: var(--c-primary);
  }
  .us-hex-map a:hover .hex-label,
  .us-hex-map a:focus-visible .hex-label {
    fill: #fff;
  }
  .us-hex-map a:focus-visible {
    outline: 3px solid var(--c-focus);
  }
  .hex-divider {
    stroke: var(--c-border-strong);
    stroke-width: 1;
  }
  .hex-caption {
    fill: var(--c-text-muted);
    font-size: 13px;
    font-weight: 700;
    text-anchor: start;
  }
  @media (prefers-reduced-motion: reduce) {
    .hex {
      transition: none;
    }
  }
  @media print {
    .us-hex-map {
      display: none;
    }
  }
</style>
