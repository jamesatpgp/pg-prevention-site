---
import BaseLayout from "../layouts/BaseLayout.astro";

const topics = [
  {
    title: "What is gambling?",
    body: "A plain definition — stake, chance, prize — and the eight main forms of gambling used across the U.S.",
    href: "/understand-gambling/what-is-gambling",
  },
  {
    title: "What is problem gambling?",
    body: "Problem gambling on a spectrum, and what DSM and ICD do and don't recognize for gambling, gaming, and screen time.",
    href: "/understand-gambling/what-is-problem-gambling",
  },
  {
    title: "Warning signs & risk factors",
    body: "Things to notice — in yourself or in someone you care about — plus risk and protective factors, and a private self-check.",
    href: "/understand-gambling/warning-signs-risk-factors",
  },
  {
    title: "Why gambling is everywhere now",
    body: "The 2018 Supreme Court decision, gambling on phones, and newer money activities that share features with gambling.",
    href: "/understand-gambling/why-now",
  },
];
---

<BaseLayout
  title="Understand Gambling"
  description="Plain-language information about gambling and gambling harm: what it is, the signs, risk factors, myths, and how to help yourself or someone you love."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Public education</p>
      <h1>Understand gambling</h1>
      <p class="page-header__lead">
        Clear, judgment-free information about gambling and gambling harm.
        Start anywhere — every page links to free help.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          topics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
