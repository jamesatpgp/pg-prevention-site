---
import CrisisCTAs from "./CrisisCTAs.astro";
---

<details class="sticky-help">
  <summary class="sticky-help__summary">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      focusable="false"
    >
      <path
        d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.58 3.6a1 1 0 0 1-.25 1L6.6 10.8Z"
        fill="currentColor"></path>
    </svg>
    <span>Get Help</span>
  </summary>
  <div class="sticky-help__panel">
    <CrisisCTAs variant="sticky" />
  </div>
</details>

<style>
  .sticky-help {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 900;
  }

  .sticky-help__summary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: var(--target-min);
    padding: var(--space-3) var(--space-5);
    background: var(--c-cta-help-bg);
    color: #fff;
    border-radius: 999px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(11, 58, 83, 0.35);
    list-style: none;
  }
  /* Hide default disclosure marker */
  .sticky-help__summary::-webkit-details-marker {
    display: none;
  }
  .sticky-help__summary:hover {
    background: var(--c-cta-help-bg-hover);
  }

  .sticky-help__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + var(--space-2));
    width: min(20rem, calc(100vw - 2 * var(--space-4)));
    padding: var(--space-4);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 28px rgba(11, 58, 83, 0.28);
  }

  @media print {
    .sticky-help {
      display: none;
    }
  }
</style>
