---
import CrisisCTAs from "./CrisisCTAs.astro";

interface NavNode {
  label: string;
  href: string;
  children?: NavNode[];
}

const navItems: NavNode[] = [
  {
    label: "Understand Gambling",
    href: "/understand-gambling",
    children: [
      { label: "What is gambling?", href: "/understand-gambling/what-is-gambling" },
      { label: "What is problem gambling?", href: "/understand-gambling/what-is-problem-gambling" },
      { label: "Signs & screening", href: "/understand-gambling/signs-and-screening" },
      { label: "Myths vs. facts", href: "/understand-gambling/myths-vs-facts" },
    ],
  },
  {
    label: "Family & Friends",
    href: "/family-and-friends",
    children: [
      { label: "For parents", href: "/family-and-friends/for-parents" },
      { label: "For children of older adults", href: "/family-and-friends/for-children-of-older-adults" },
      { label: "For friends", href: "/family-and-friends/for-friends" },
      { label: "For veterans", href: "/family-and-friends/for-veterans" },
    ],
  },
  {
    label: "Professionals",
    href: "/professionals",
    children: [
      { label: "Prevention Specialists", href: "/professionals/prevention-specialists" },
      { label: "Treatment Providers", href: "/professionals/treatment-providers" },
      { label: "Healthcare Providers", href: "/professionals/healthcare-providers" },
      { label: "Teachers", href: "/professionals/teachers" },
    ],
  },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
const ariaCurrent = (href: string): "page" | undefined =>
  current === href ? "page" : undefined;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="site-wordmark pgp-wordmark" href="/" aria-label="PGPrevention.com, home">
      <span class="pgp-wordmark__pg">PG</span><span class="pgp-wordmark__prevention">Prevention</span><span class="pgp-wordmark__tld">.com</span>
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <svg
        class="nav-toggle__icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M3 6h18M3 12h18M3 18h18"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
      <span class="nav-toggle__text">Menu</span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul class="primary-nav__list">
        {
          navItems.map((item) => (
            <li class:list={["nav-item", { "nav-item--has-menu": item.children }]}>
              <a href={item.href} aria-current={ariaCurrent(item.href)}>
                {item.label}
                {item.children && <span class="nav-caret" aria-hidden="true">▾</span>}
              </a>
              {item.children && (
                <ul class="nav-menu">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href} aria-current={ariaCurrent(child.href)}>
                        {child.label}
                      </a>
                      {child.children && (
                        <ul class="nav-submenu">
                          {child.children.map((gc) => (
                            <li>
                              <a href={gc.href} aria-current={ariaCurrent(gc.href)}>
                                {gc.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-ctas">
      <CrisisCTAs variant="nav" />
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "brand toggle"
      "ctas  ctas"
      "nav   nav";
    gap: var(--space-4);
    align-items: center;
    padding-block: var(--space-4);
  }

  /* Wordmark — PG[Prevention].com lockup (visual styles in global .pgp-wordmark) */
  .site-wordmark {
    grid-area: brand;
    font-size: 1.5rem;
  }

  /* Hamburger toggle */
  .nav-toggle {
    grid-area: toggle;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: var(--target-min);
    min-width: var(--target-min);
    padding: var(--space-2) var(--space-3);
    background: var(--c-surface);
    border: 2px solid var(--c-border-strong);
    border-radius: var(--radius);
    color: var(--c-heading);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  /* Primary nav */
  .primary-nav {
    grid-area: nav;
    display: none;
  }
  .primary-nav.is-open {
    display: block;
  }
  .primary-nav__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .nav-menu,
  .nav-submenu {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* Mobile: nested items show indented inside the open menu */
  .nav-menu {
    padding-left: var(--space-4);
  }
  .nav-submenu {
    padding-left: var(--space-4);
  }
  .primary-nav__list a {
    display: block;
    min-height: var(--target-min);
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius);
    color: var(--c-text);
    text-decoration: none;
    font-weight: 600;
  }
  .nav-menu a {
    font-weight: 500;
  }
  .primary-nav__list a:hover {
    background: var(--c-surface-alt);
    color: var(--c-primary-hover);
  }
  .primary-nav__list a[aria-current="page"] {
    color: var(--c-primary);
    box-shadow: inset 3px 0 0 var(--c-primary);
  }
  .nav-caret {
    margin-left: var(--space-1);
    font-size: 0.7em;
    color: var(--c-text-muted);
  }

  .header-ctas {
    grid-area: ctas;
  }

  /* Desktop: single row, full nav visible, no hamburger */
  @media (min-width: 64em) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
      grid-template-areas: "brand nav ctas";
      gap: var(--space-6);
    }
    .nav-toggle {
      display: none;
    }
    .primary-nav {
      display: block;
    }
    .primary-nav__list {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: var(--space-2);
    }
    .primary-nav__list a[aria-current="page"] {
      box-shadow: inset 0 -3px 0 var(--c-primary);
    }
    .crisis-ctas--nav {
      align-items: stretch;
    }

    /* Dropdown menu (hover + keyboard focus reveal) */
    .nav-item--has-menu {
      position: relative;
    }
    .nav-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      min-width: 17rem;
      margin-top: var(--space-1);
      padding: var(--space-2);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius);
      box-shadow: 0 8px 24px rgba(31, 48, 36, 0.12);
      z-index: 800;
    }
    .nav-item--has-menu:hover > .nav-menu,
    .nav-item--has-menu:focus-within > .nav-menu {
      display: block;
    }
    .nav-submenu {
      padding-left: var(--space-4);
    }
    .nav-menu a[aria-current="page"] {
      box-shadow: inset 3px 0 0 var(--c-primary);
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const nav = document.getElementById("primary-nav");
  if (toggle && nav) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      nav.classList.toggle("is-open", open);
    };
    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });
    // Close when a link is chosen.
    nav.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) setOpen(false);
    });
    // Close on Escape and return focus to the toggle.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        toggle.focus();
      }
    });
  }
</script>
