---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllJurisdictions,
  getJurisdiction,
  type LegalStatus,
} from "../../lib/jurisdictions";

export async function getStaticPaths() {
  return getAllJurisdictions().map((j) => ({ params: { slug: j.slug } }));
}

const { slug } = Astro.params;
const j = getJurisdiction(slug!);
if (!j) return Astro.redirect("/find-your-state");

const statusLabel: Record<LegalStatus, string> = {
  authorized: "Authorized",
  limited: "Limited / unsettled",
  "tribal-only": "Tribal only",
  "not-authorized": "Not authorized",
};

const hasPrevention =
  j.help.affiliateName ||
  j.help.preventionOrg ||
  j.help.treatmentDirectoryUrl ||
  j.help.affiliateUrl;

// Derived structural stats (real archive data; population stats are a gap).
const authorizedCount = j.legal.filter((v) => v.status === "authorized").length;
const years = j.legal
  .map((v) => (v.year ? parseInt(v.year, 10) : null))
  .filter((y): y is number => y !== null && !Number.isNaN(y));
const earliestYear = years.length ? Math.min(...years) : null;
// Authorized types with a statute citation, for the regulation-process view.
const processItems = j.legal.filter(
  (v) => v.status === "authorized" && v.citation && v.id !== "tribal",
);
const tribalAuthorized = j.legal.find((v) => v.id === "tribal")?.status === "authorized";
---

<BaseLayout
  title={`Gambling in ${j.name}`}
  description={`Helplines, who regulates gambling, what's legal, and where to find help in ${j.name}. The National Problem Gambling Helpline is 1-800-MY-RESET.`}
>
  <div class="container breadcrumb">
    <a href="/find-your-state">← All states &amp; territories</a>
  </div>

  <!-- 1. Helpline banner -->
  <section class="helpline-banner" aria-label={`Get help in ${j.name}`}>
    <div class="container">
      <h1>{j.name}</h1>
      <div class="helpline-grid">
        <a
          class="helpline-card helpline-card--national"
          href={`tel:${j.helpline.national.tel}`}
        >
          <img
            class="myreset-lockup"
            src="/brand/myreset-horizontal-color.png"
            width="640"
            height="162"
            alt="Call or text 1-800-MY-RESET, the National Problem Gambling Helpline"
          />
        </a>

        <a class="helpline-card helpline-card--988" href="tel:988">
          <img
            class="lifeline-988-logo"
            src="/brand/988-horizontal-navy.png"
            width="640"
            height="124"
            alt="Call or text 988, the Suicide & Crisis Lifeline"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- At a glance (structural stats) -->
  <section class="section glance-section" aria-labelledby="glance-h">
    <div class="container">
      <h2 id="glance-h" class="visually-hidden">{j.name} at a glance</h2>
      <ul class="glance">
        <li class="glance__item">
          <span class="glance__num">{authorizedCount}<span class="glance__den">/8</span></span>
          <span class="glance__label">gambling types authorized</span>
        </li>
        <li class="glance__item">
          <span class="glance__num">{j.regulators.primary.length}</span>
          <span class="glance__label">state-level regulators</span>
        </li>
        <li class="glance__item">
          <span class="glance__num">{j.regulators.tribalCount}</span>
          <span class="glance__label">tribal gaming commissions</span>
        </li>
        <li class="glance__item">
          <span class="glance__num">{earliestYear ?? "—"}</span>
          <span class="glance__label">earliest authorization</span>
        </li>
      </ul>
      <p class="fine-print">
        Adult and youth prevalence data for {j.name} is coming soon.
      </p>
    </div>
  </section>

  <!-- 2. Gambling in [State] -->
  {
    j.summary && (
      <section class="section" aria-labelledby="summary-h">
        <div class="container">
          <h2 id="summary-h">Gambling in {j.name}</h2>
          <p class="lead">{j.summary}</p>
        </div>
      </section>
    )
  }

  <!-- 3. Legal gambling types -->
  <section class="section section-alt" aria-labelledby="legal-h">
    <div class="container">
      <h2 id="legal-h">What kinds of gambling are legal in {j.name}?</h2>
      <ul class="legal-grid">
        {
          j.legal.map((v) => (
            <li class={`legal-cell legal-cell--${v.status}`}>
              <span class="legal-cell__status" aria-hidden="true">
                {v.status === "authorized" ? "✓" : v.status === "not-authorized" ? "—" : "•"}
              </span>
              <span class="legal-cell__label">{v.label}</span>
              <span class="legal-cell__state">
                {v.year ? `${statusLabel[v.status]} (since ${v.year})` : statusLabel[v.status]}
              </span>
              {v.citation && (
                <span class="legal-cell__cite">
                  {v.url ? <a href={v.url}>{v.citation}</a> : v.citation}
                </span>
              )}
            </li>
          ))
        }
      </ul>
      <p class="fine-print">
        Based on our statute inventory{j.retrievalDate ? `, retrieved ${j.retrievalDate}` : ""}.
        "Not authorized" means no authorizing statute is on file. See each citation
        for the source.
      </p>
    </div>
  </section>

  <!-- 4. How gambling is regulated (the process) -->
  <section class="section" aria-labelledby="reg-h">
    <div class="container">
      <h2 id="reg-h">How gambling is regulated in {j.name}</h2>
      <p class="lead">
        Each legal form of gambling moves through the same layered process: a
        <strong>statute</strong> in the state code authorizes it,
        <strong>administrative rules</strong> spell out the details, and a
        <strong>commission or agency</strong> licenses and enforces it.
      </p>

      {
        processItems.length > 0 && (
          <ol class="process-list">
            {processItems.map((v) => (
              <li class="process">
                <p class="process__type">
                  {v.year ? `${v.label} · since ${v.year}` : v.label}
                </p>
                <ol class="process__chain">
                  <li class="proc">
                    <span class="proc__step">Law</span>
                    <span class="proc__body">
                      {v.url ? <a href={v.url}>{v.citation}</a> : v.citation}
                    </span>
                  </li>
                  <li class="proc proc--pending">
                    <span class="proc__step">Rules</span>
                    <span class="proc__body">Administrative code — coming soon</span>
                  </li>
                  <li class="proc">
                    <span class="proc__step">Regulator</span>
                    <span class="proc__body">{v.agency ?? "—"}</span>
                  </li>
                </ol>
              </li>
            ))}
          </ol>
        )
      }

      {
        tribalAuthorized && (
          <p class="tribal-note">
            Tribal gaming is regulated under federal law (the Indian Gaming
            Regulatory Act) through the National Indian Gaming Commission and
            tribal–state compacts, with {j.regulators.tribalCount} tribal gaming
            commission{j.regulators.tribalCount === 1 ? "" : "s"} on file (listed
            below).
          </p>
        )
      }

      <h3 class="reg-dir-h">Regulators in {j.name}</h3>
      {
        j.regulators.primary.length === 0 && (
          <p>No state-level gambling regulator is on file for {j.name}.</p>
        )
      }
      <ul class="reg-list">
        {
          j.regulators.primary.map((r) => (
            <li class="reg-item">
              <p class="reg-item__name">
                {r.website ? <a href={r.website}>{r.name}</a> : r.name}
              </p>
              <p class="reg-item__type">{r.type}</p>
              {r.phone && <p class="reg-item__meta">{r.phone}</p>}
            </li>
          ))
        }
      </ul>

      {
        (j.regulators.tribalCount > 0 || j.regulators.county.length > 0) && (
          <details class="reg-more">
            <summary>
              Show tribal and county regulators
              {j.regulators.tribalCount > 0
                ? ` (${j.regulators.tribalCount} tribal gaming commission${j.regulators.tribalCount === 1 ? "" : "s"})`
                : ""}
            </summary>
            <ul class="reg-list reg-list--sub">
              {j.regulators.county.map((r) => (
                <li class="reg-item">
                  <p class="reg-item__name">
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </p>
                  <p class="reg-item__type">{r.type}</p>
                </li>
              ))}
              {j.regulators.tribal.map((r) => (
                <li class="reg-item">
                  <p class="reg-item__name">
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </p>
                  <p class="reg-item__type">{r.type}</p>
                </li>
              ))}
            </ul>
          </details>
        )
      }
    </div>
  </section>

  <!-- 5. Get help in [State] -->
  <section class="section section-alt" aria-labelledby="help-h">
    <div class="container">
      <h2 id="help-h">Get help in {j.name}</h2>
      {
        hasPrevention ? (
          <ul class="help-list">
            {(j.help.affiliateName || j.help.affiliateUrl) && (
              <li>
                <strong>NCPG affiliate:</strong>{" "}
                {j.help.affiliateUrl ? (
                  <a href={j.help.affiliateUrl}>{j.help.affiliateName ?? j.help.affiliateUrl}</a>
                ) : (
                  j.help.affiliateName
                )}
              </li>
            )}
            {j.help.preventionOrg && j.help.preventionOrg !== j.help.affiliateName && (
              <li>
                <strong>Prevention &amp; treatment:</strong>{" "}
                {j.help.preventionUrl ? (
                  <a href={j.help.preventionUrl}>{j.help.preventionOrg}</a>
                ) : (
                  j.help.preventionOrg
                )}
              </li>
            )}
            {j.help.treatmentDirectoryUrl && (
              <li>
                <strong>Find treatment:</strong>{" "}
                <a href={j.help.treatmentDirectoryUrl}>Treatment directory</a>
              </li>
            )}
          </ul>
        ) : (
          <p>
            No state-specific organization is listed for {j.name}. The national
            helpline above and the{" "}
            <a href="https://www.ncpgambling.org/help-treatment/treatment-facilities/">
              NCPG treatment directory
            </a>{" "}
            can still help.
          </p>
        )
      }
    </div>
  </section>

  <!-- 6. Resources (Phase 4 placeholder) -->
  <section class="section" aria-labelledby="res-h">
    <div class="container">
      <h2 id="res-h">Resources for {j.name}</h2>
      <p class="coming">
        Downloadable rack cards and fact sheets customized for {j.name} are
        coming soon. In the meantime, browse the{" "}
        <a href="/resources">Resource Library</a>.
      </p>
    </div>
  </section>

  <!-- 7. Self-exclusion (data gap placeholder) -->
  <section class="section section-alt" aria-labelledby="se-h">
    <div class="container">
      <h2 id="se-h">Self-exclusion in {j.name}</h2>
      <p class="coming">
        Details about {j.name}'s voluntary self-exclusion options are coming
        soon. To talk through your options now, call or text{" "}
        <a href={`tel:${j.helpline.national.tel}`}>{j.helpline.national.label}</a>.
      </p>
    </div>
  </section>

  <!-- Funding & transparency intentionally omitted for now: no revenue /
       taxation / funding figures until that content is handled deliberately.
       The funding data is retained in the archive + data layer. -->

  <!-- Brief history intentionally hidden for now: the archival narratives
       contain revenue / taxation / funding figures (e.g., PGNO funding amounts)
       that can't be surgically removed from verbatim prose. The history files
       and the `history` content collection are retained; re-enable after a
       figure review. -->

  <style>
    .breadcrumb {
      padding-top: var(--space-5);
    }
    .breadcrumb a {
      font-weight: 600;
    }

    /* Helpline banner */
    .helpline-banner {
      background: var(--c-primary-tint);
      padding-block: var(--space-8);
      border-bottom: 1px solid var(--c-border);
    }
    .helpline-banner h1 {
      margin-bottom: var(--space-5);
    }
    .helpline-grid {
      display: grid;
      gap: var(--space-4);
    }
    @media (min-width: 48em) {
      .helpline-grid {
        grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
      }
    }
    .helpline-card {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      text-decoration: none;
    }
    .helpline-card--national {
      border: 2px solid var(--c-primary);
    }
    .myreset-lockup {
      display: block;
      width: 100%;
      max-width: 15rem;
      height: auto;
    }
    .lifeline-988-logo {
      display: block;
      width: 100%;
      max-width: 12rem;
      height: auto;
    }

    .lead {
      font-size: 1.2rem;
      max-width: 70ch;
    }

    /* At a glance */
    .glance-section {
      padding-block: var(--space-6);
    }
    .glance {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    }
    .glance__item {
      padding: var(--space-4);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      text-align: center;
    }
    .glance__num {
      display: block;
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--c-heading);
      line-height: 1.1;
    }
    .glance__den {
      font-size: 1.2rem;
      color: var(--c-text-muted);
    }
    .glance__label {
      display: block;
      margin-top: var(--space-2);
      color: var(--c-text-muted);
      font-size: 0.9rem;
    }

    /* Regulation process */
    .process-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      margin: var(--space-6) 0;
    }
    .process {
      padding: var(--space-5);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-left: 4px solid var(--c-primary);
      border-radius: var(--radius-lg);
    }
    .process__type {
      margin: 0 0 var(--space-3);
      font-weight: 800;
      color: var(--c-heading);
      font-size: 1.1rem;
    }
    .process__chain {
      list-style: none;
      display: grid;
      gap: var(--space-3);
    }
    @media (min-width: 48em) {
      .process__chain {
        grid-template-columns: 1fr 1fr 1fr;
        align-items: stretch;
      }
    }
    .proc {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
      padding: var(--space-3);
      background: var(--c-surface-alt);
      border-radius: var(--radius);
      position: relative;
    }
    .proc--pending {
      background: transparent;
      border: 1px dashed var(--c-border-strong);
    }
    .proc__step {
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--c-primary);
    }
    .proc--pending .proc__step {
      color: var(--c-text-muted);
    }
    .proc__body {
      font-size: 0.95rem;
      word-break: break-word;
    }
    /* Connector arrows between steps (decorative) */
    @media (min-width: 48em) {
      .proc + .proc::before {
        content: "→";
        position: absolute;
        left: calc(var(--space-3) * -1 - 0.4em);
        top: 50%;
        transform: translateY(-50%);
        color: var(--c-border-strong);
        font-weight: 800;
      }
    }
    .tribal-note,
    .reg-dir-h {
      max-width: 70ch;
    }
    .reg-dir-h {
      margin-top: var(--space-8);
      font-size: 1.2rem;
    }

    /* Legal grid */
    .legal-grid {
      list-style: none;
      display: grid;
      gap: var(--space-3);
      grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    }
    .legal-cell {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-areas: "icon label" "icon state" "cite cite";
      gap: 0 var(--space-3);
      padding: var(--space-4);
      border: 1px solid var(--c-border);
      border-radius: var(--radius);
      background: var(--c-surface);
    }
    .legal-cell--authorized {
      border-left: 4px solid var(--c-primary);
    }
    .legal-cell--not-authorized {
      background: var(--c-surface-alt);
    }
    .legal-cell--tribal-only,
    .legal-cell--limited {
      border-left: 4px solid var(--c-border-strong);
    }
    .legal-cell__status {
      grid-area: icon;
      font-weight: 800;
      font-size: 1.25rem;
      color: var(--c-primary);
    }
    .legal-cell--not-authorized .legal-cell__status {
      color: var(--c-text-muted);
    }
    .legal-cell__label {
      grid-area: label;
      font-weight: 700;
      color: var(--c-heading);
    }
    .legal-cell__state {
      grid-area: state;
      color: var(--c-text-muted);
      font-size: 0.95rem;
    }
    .legal-cell__cite {
      grid-area: cite;
      margin-top: var(--space-2);
      font-size: 0.8rem;
      word-break: break-word;
    }

    .fine-print {
      margin-top: var(--space-5);
      font-size: 0.85rem;
      color: var(--c-text-muted);
      max-width: 70ch;
    }

    /* Regulators */
    .reg-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    }
    .reg-list--sub {
      margin-top: var(--space-4);
    }
    .reg-item__name {
      margin: 0;
      font-weight: 700;
    }
    .reg-item__type,
    .reg-item__meta {
      margin: var(--space-1) 0 0;
      color: var(--c-text-muted);
      font-size: 0.9rem;
    }
    .reg-more {
      margin-top: var(--space-5);
    }
    .reg-more summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--c-primary);
      min-height: var(--target-min);
      display: flex;
      align-items: center;
    }

    .help-list {
      list-style: none;
      display: grid;
      gap: var(--space-3);
    }
    .coming {
      color: var(--c-text-muted);
    }

    /* History */
    .history summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--c-primary);
      min-height: var(--target-min);
      display: flex;
      align-items: center;
    }
    .history__body {
      margin-top: var(--space-4);
      max-width: 70ch;
    }
    .history__body :global(h2) {
      font-size: 1.3rem;
      margin-top: var(--space-6);
    }
    .history__body :global(h3) {
      font-size: 1.1rem;
    }
  </style>
</BaseLayout>
