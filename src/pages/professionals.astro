---
import BaseLayout from "../layouts/BaseLayout.astro";

const audiences = [
  {
    slug: "prevention-specialists",
    title: "Prevention Specialists",
    href: "/professionals/prevention-specialists",
  },
  {
    slug: "treatment-providers",
    title: "Treatment Providers",
    href: "/professionals/treatment-providers",
  },
  {
    slug: "healthcare-providers",
    title: "Healthcare Providers",
    href: "/professionals/healthcare-providers",
  },
  {
    slug: "teachers",
    title: "Teachers",
    href: "/professionals/teachers",
  },
];
---

<BaseLayout
  title="Professionals"
  description="How prevention specialists, treatment providers, healthcare providers, and teachers can bring problem gambling prevention into their work."
>
  <header class="page-header">
    <div class="container">
      <h1>Professionals</h1>
      <p class="page-header__lead">
        How to bring problem gambling prevention into your work. Pick your
        role.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="audience-grid">
        {
          audiences.map((a) => (
            <li>
              <a
                class="audience-card"
                href={a.href}
                aria-label={`Read the full ${a.title} guide`}
              >
                <img
                  class="audience-card__photo"
                  src={`/photos/professionals/${a.slug}.jpg`}
                  alt=""
                  role="presentation"
                  width="200"
                  height="200"
                  loading="lazy"
                />
                <p class="audience-card__eyebrow">Guidance for</p>
                <h2 class="audience-card__title">{a.title}</h2>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="audience-escape">
        Working in a different role? Browse the
        <a href="/resources">Resource Library</a>, or
        <a href="mailto:james@pgprevention.com">send a note</a>.
      </p>
    </div>
  </section>
</BaseLayout>
