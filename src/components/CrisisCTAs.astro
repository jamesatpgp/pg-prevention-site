---
// Stacked crisis-help CTA pair using the official helpline logo lockups
// (white variants on filled buttons). 1-800-MY-RESET (primary) + 988
// (secondary). Compliance: vanity (logo) + digits (text) shown; "Free. 24/7.
// Call or text." disclosure; person-first; no categorical confidentiality claims.
interface Props {
  variant?: "nav" | "sticky";
}
const { variant = "nav" } = Astro.props;
---

<div class:list={["crisis-ctas", `crisis-ctas--${variant}`]}>
  <a class="cta cta--help" href="tel:+18006973738">
    <img
      class="cta__logo cta__logo--myreset"
      src="/brand/myreset-horizontal-white.png"
      width="640"
      height="199"
      alt="1-800-MY-RESET, the National Problem Gambling Helpline"
    />
    <span class="cta__action">Call or text · 1-800-697-3738</span>
  </a>
  <a class="cta cta--988" href="tel:988">
    <img
      class="cta__logo cta__logo--988"
      src="/brand/988-horizontal-white.png"
      width="640"
      height="124"
      alt="988 Suicide & Crisis Lifeline"
    />
    <span class="cta__action">Call or text · in a crisis</span>
  </a>
  <p class="crisis-ctas__note">Free. 24/7. Call or text.</p>
</div>

<style>
  .crisis-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .cta--help {
    background: var(--c-cta-help-bg);
  }
  .cta--help:hover {
    background: var(--c-cta-help-bg-hover);
  }

  .cta--988 {
    background: var(--c-cta-988-bg);
  }
  .cta--988:hover {
    background: var(--c-cta-988-bg-hover);
  }

  .cta__logo {
    height: auto;
    max-width: 100%;
  }
  /* Both lockups share a width so the stacked pair reads as a balanced set. */
  .cta__logo--myreset {
    width: 7.5rem;
  }
  .cta__logo--988 {
    width: 7.5rem;
  }

  .cta__action {
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .crisis-ctas__note {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text-muted);
    text-align: center;
  }
  .crisis-ctas--sticky .crisis-ctas__note {
    color: var(--c-text);
  }
</style>
