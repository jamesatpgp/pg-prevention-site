---
import BaseLayout from "../layouts/BaseLayout.astro";
import USGeoMap from "../components/USGeoMap.astro";
import StateSelect from "../components/StateSelect.astro";

const learnTopics = [
  { title: "What is gambling?", body: "The common forms of gambling, and how access has changed.", href: "/understand-gambling/what-is-gambling" },
  { title: "What is problem gambling?", body: "What it means, in plain language.", href: "/understand-gambling/what-is-problem-gambling" },
  { title: "Signs & screening", body: "Warning signs, and quick questions that can help.", href: "/understand-gambling/signs-and-screening" },
  { title: "Myths vs. facts", body: "Common misunderstandings, corrected.", href: "/understand-gambling/myths-vs-facts" },
];

const familyTopics = [
  { title: "For parents", body: "Navigating a family member's gambling — or your own.", href: "/family-and-friends/for-parents" },
  { title: "For children of older adults", body: "Concerned about an aging parent's gambling.", href: "/family-and-friends/for-children-of-older-adults" },
  { title: "For friends", body: "Supporting a friend whose gambling may be causing harm.", href: "/family-and-friends/for-friends" },
  { title: "For veterans", body: "Gambling-harm resources for those who have served.", href: "/family-and-friends/for-veterans" },
];

const professionalsTopics = [
  { title: "Prevention Specialists", body: "For credentialed prevention specialists.", href: "/professionals/prevention-specialists" },
  { title: "Treatment Providers", body: "Screening and referral for treatment providers.", href: "/professionals/treatment-providers" },
  { title: "Healthcare Providers", body: "For doctors, dentists, and other clinicians.", href: "/professionals/healthcare-providers" },
  { title: "Teachers", body: "Classroom-ready resources for educators.", href: "/professionals/teachers" },
];
---

<BaseLayout>
  <!-- Hero: the map is the hero; find your state -->
  <section class="hero">
    <div class="container">
      <p class="hero__eyebrow">
        Problem Gambling Prevention
      </p>
      <h1 class="hero__headline">
        Information you can trust about gambling and gambling harm.
      </h1>
      <p class="hero__subhead">
        For two audiences: people looking for answers, and the prevention
        professionals who serve them. Start with your state.
      </p>
      <div class="state-finder hero__finder">
        <div class="state-finder__map">
          <USGeoMap />
        </div>
        <div class="state-finder__pick">
          <StateSelect />
        </div>
      </div>
    </div>
  </section>

  <!-- Understand Gambling featured -->
  <section class="section" aria-labelledby="learn-heading">
    <div class="container">
      <h2 id="learn-heading">Understand gambling</h2>
      <p class="section-lead">
        Clear, judgment-free information about gambling and gambling harm.
      </p>
      <ul class="card-grid">
        {
          learnTopics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="learn-all">
        <a href="/understand-gambling">See all Understand Gambling topics →</a>
      </p>
    </div>
  </section>

  <!-- Family & Friends -->
  <section class="section section-alt" aria-labelledby="family-heading">
    <div class="container">
      <h2 id="family-heading">Family &amp; friends</h2>
      <p class="section-lead">
        Support and information for the people around someone affected by
        gambling.
      </p>
      <ul class="card-grid">
        {
          familyTopics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="learn-all">
        <a href="/family-and-friends">See all Family &amp; friends resources →</a>
      </p>
    </div>
  </section>

  <!-- Professionals -->
  <section class="section" aria-labelledby="pro-heading">
    <div class="container">
      <h2 id="pro-heading">Professionals</h2>
      <p class="section-lead">
        Problem gambling prevention resources, organized by the profession
        they're for.
      </p>
      <ul class="card-grid">
        {
          professionalsTopics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="learn-all">
        <a href="/professionals">See all Professionals resources →</a>
      </p>
    </div>
  </section>

  <style>
    .section-lead {
      font-size: 1.15rem;
      max-width: 60ch;
      margin-bottom: var(--space-6);
    }
    .learn-all {
      margin-top: var(--space-5);
      font-weight: 700;
    }

    /* Find Your State: map beside the picker */
    .state-finder {
      display: grid;
      gap: var(--space-6);
      align-items: center;
    }
    @media (min-width: 48em) {
      .state-finder {
        grid-template-columns: 1.4fr 1fr;
      }
    }
    @media (max-width: 47.99em) {
      .state-finder__map {
        display: none;
      }
    }

    /* Hero */
    .hero {
      padding-block: var(--space-12) var(--space-10);
      background: var(--c-bg);
    }
    .hero__eyebrow {
      margin: 0 0 var(--space-4);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--c-link);
      font-size: 0.9rem;
    }
    .hero__headline {
      max-width: 18ch;
      margin-bottom: var(--space-5);
    }
    .hero__subhead {
      font-size: 1.25rem;
      max-width: 52ch;
      color: var(--c-text);
      margin-bottom: var(--space-6);
    }
    .hero__finder {
      margin-top: var(--space-2);
    }
  </style>
</BaseLayout>
