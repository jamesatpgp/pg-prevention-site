---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HelpCallout from "../../components/HelpCallout.astro";
---

<BaseLayout
  title="For friends"
  description="Gambling-harm support and information for friends of someone who may be experiencing harm."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">
        <a href="/family-and-friends">← Family &amp; friends</a>
      </p>
      <h1>For friends</h1>
      <p class="page-header__lead">
        Support and information for friends of someone whose gambling may be
        causing harm.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container prose">
      <p>Resources for friends are being developed. <em>[Content coming soon.]</em></p>
      <HelpCallout />
    </div>
  </section>
</BaseLayout>
