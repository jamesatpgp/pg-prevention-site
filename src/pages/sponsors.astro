---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sponsors & Partners"
  description="How sponsorship supports this site, and how to get involved."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">About</p>
      <h1>Sponsors &amp; partners</h1>
      <p class="page-header__lead">
        Sponsorship and partnerships help support and grow this site.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container prose">
      <h2>How sponsorship works here</h2>
      <p>
        Sponsorship helps fund building and maintaining this site. Sponsors are
        recognized on this page and in a dedicated band in the footer.
      </p>

      <h2>Our sponsors</h2>
      <div class="sponsor-band" role="img" aria-label="Sponsor logos will appear here">
        <span>Sponsor logos will appear here.</span>
      </div>

      <h2>Interested in sponsoring or partnering?</h2>
      <p>
        We welcome conversations with organizations interested in supporting
        problem gambling prevention. <em>[Sponsorship details and contact to be
        added.]</em> See <a href="/about">About</a> for more on the site.
      </p>
    </div>
  </section>

  <style>
    .sponsor-band {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 110px;
      border: 2px dashed var(--c-border-strong);
      border-radius: var(--radius-lg);
      color: var(--c-text-muted);
      font-weight: 600;
    }
  </style>
</BaseLayout>
