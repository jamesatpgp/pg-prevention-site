---
// Stacked crisis-help CTA pair: the official helpline logo lockups (white
// variants) centered on filled tap-to-call buttons. The lockups carry the
// numbers themselves, so no added text. 1-800-MY-RESET (primary) + 988.
interface Props {
  variant?: "nav" | "sticky";
}
const { variant = "nav" } = Astro.props;
---

<div class:list={["crisis-ctas", `crisis-ctas--${variant}`]}>
  <a class="cta cta--help" href="tel:+18006973738">
    <img
      class="cta__logo cta__logo--myreset"
      src="/brand/myreset-horizontal-white.png"
      width="640"
      height="199"
      alt="1-800-MY-RESET, the National Problem Gambling Helpline"
    />
  </a>
  <a class="cta cta--988" href="tel:988">
    <img
      class="cta__logo cta__logo--988"
      src="/brand/988-horizontal-white.png"
      width="640"
      height="124"
      alt="988 Suicide & Crisis Lifeline"
    />
  </a>
</div>

<style>
  .crisis-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .cta--help {
    background: var(--c-cta-help-bg);
  }
  .cta--help:hover {
    background: var(--c-cta-help-bg-hover);
  }

  .cta--988 {
    background: var(--c-cta-988-bg);
  }
  .cta--988:hover {
    background: var(--c-cta-988-bg-hover);
  }

  /* Both lockups share a width so the stacked pair reads as a balanced set. */
  .cta__logo {
    height: auto;
    max-width: 100%;
  }
  .cta__logo--myreset {
    width: 7.5rem;
  }
  .cta__logo--988 {
    width: 7.5rem;
  }
</style>
