---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HelpCallout from "../../components/HelpCallout.astro";
---

<BaseLayout
  title="For parents"
  description="Gambling-harm support and information for parents."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">
        <a href="/family-and-friends">← Family &amp; friends</a>
      </p>
      <h1>For parents</h1>
      <p class="page-header__lead">
        Support and information for parents navigating gambling — a child's, a
        partner's, or their own.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container prose">
      <p>Resources for parents are being developed. <em>[Content coming soon.]</em></p>
      <HelpCallout />
    </div>
  </section>
</BaseLayout>
