---
import BaseLayout from "../layouts/BaseLayout.astro";
import HelpCallout from "../components/HelpCallout.astro";

const audiences = [
  { title: "Youth", body: "Worried about a young person? How to recognize it and talk with them.", href: "/family-and-friends/youth" },
  { title: "Young Adults", body: "Concerned about a young adult? How to raise it and what to say.", href: "/family-and-friends/young-adults" },
  { title: "Older Adults", body: "Concerned about an older adult? How to bring it up with care.", href: "/family-and-friends/older-adults" },
  { title: "Veterans", body: "Supporting a veteran? How to talk about gambling.", href: "/family-and-friends/veterans" },
];
---

<BaseLayout
  title="Family & Friends"
  description="Support and information for the people around someone affected by gambling — parents, adult children, friends, and veterans."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Family &amp; friends</p>
      <h1>Family &amp; friends</h1>
      <p class="page-header__lead">
        Worried about someone's gambling? These pages help you understand the
        risk and talk with them about it — starting with who you're concerned
        about.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          audiences.map((a) => (
            <li>
              <a class="card-link" href={a.href}>
                <span class="card-link__title">{a.title}</span>
                <span>{a.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <HelpCallout />
    </div>
  </section>
</BaseLayout>
