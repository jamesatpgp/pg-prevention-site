---
import USGeoMap from "./USGeoMap.astro";
import USHexMap from "./USHexMap.astro";
import JurisdictionList from "./JurisdictionList.astro";
---

<section class="find-your-state" aria-labelledby="find-your-state-heading">
  <div class="container">
    <h2 id="find-your-state-heading">Find your state or territory</h2>
    <p class="lead">
      Select your state or territory for local helplines, who regulates
      gambling there, what's legal, and where to find help. We cover all 50
      states, the District of Columbia, and five U.S. territories.
    </p>

    <USGeoMap />

    <div class="fys-map-wrap">
      <USHexMap />
    </div>

    <h3 class="fys-list-heading">Or pick your state or territory from this list</h3>
    <JurisdictionList />
  </div>
</section>

<style>
  .lead {
    font-size: 1.2rem;
    max-width: 60ch;
  }
  /* Geo map (desktop only, dominant). */
  .find-your-state :global(.us-geo-map) {
    max-width: 46rem;
    margin: var(--space-6) auto 0;
  }
  /* Hex map: >=44px tap targets on mobile (scrolls if needed); compact on
     desktop, where it's the secondary "quick view" beside the geo map. */
  .fys-map-wrap {
    margin: var(--space-5) 0 var(--space-8);
    overflow-x: auto;
  }
  .fys-map-wrap :global(.us-hex-map) {
    min-width: 34rem;
    margin-inline: auto;
  }
  @media (min-width: 48em) {
    .fys-map-wrap {
      overflow-x: visible;
    }
    .fys-map-wrap :global(.us-hex-map) {
      min-width: 0;
      max-width: 28rem;
    }
  }
  .fys-list-heading {
    font-size: 1.15rem;
    margin-bottom: var(--space-4);
  }
</style>
