---
import BaseLayout from "../layouts/BaseLayout.astro";
import USGeoMap from "../components/USGeoMap.astro";
import StateSelect from "../components/StateSelect.astro";

const learnTopics = [
  { title: "What is gambling?", body: "The eight main forms, in plain language.", href: "/understand-gambling/what-is-gambling" },
  { title: "What is problem gambling?", body: "On a spectrum — and what DSM/ICD recognize.", href: "/understand-gambling/what-is-problem-gambling" },
  { title: "Warning signs & risk factors", body: "What to notice, plus a private self-check.", href: "/understand-gambling/warning-signs-risk-factors" },
  { title: "Why gambling is everywhere now", body: "PASPA, online play, and gambling-like apps.", href: "/understand-gambling/why-now" },
];

const familyTopics = [
  { title: "Youth", body: "Worried about a young person? How to talk with them.", href: "/family-and-friends/youth" },
  { title: "Young Adults", body: "Concerned about a young adult's gambling?", href: "/family-and-friends/young-adults" },
  { title: "Older Adults", body: "Concerned about an older adult? How to bring it up.", href: "/family-and-friends/older-adults" },
  { title: "Veterans", body: "Supporting a veteran — starting the conversation.", href: "/family-and-friends/veterans" },
];

const professionalsTopics = [
  { title: "Human Resources", body: "Workplace policies and employee wellness.", href: "/professionals/human-resources" },
  { title: "Treatment Providers", body: "Incorporate prevention into your practice.", href: "/professionals/treatment-providers" },
  { title: "Healthcare Providers", body: "Work prevention into routine care.", href: "/professionals/healthcare-providers" },
  { title: "Teachers", body: "Bring prevention into the classroom.", href: "/professionals/teachers" },
];
---

<BaseLayout>
  <!-- Hero: the map is the hero; find your state -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__headline">Problem Gambling Prevention</h1>
      <p class="hero__subhead">
        For two audiences: people looking for answers, and the prevention
        professionals who serve them. Start with your state.
      </p>
      <div class="state-finder hero__finder">
        <div class="state-finder__map">
          <USGeoMap />
        </div>
        <div class="state-finder__pick">
          <StateSelect />
        </div>
      </div>
    </div>
  </section>

  <!-- Understand Gambling featured -->
  <section class="section" aria-labelledby="learn-heading">
    <div class="container">
      <h2 id="learn-heading"><a class="section-link" href="/understand-gambling">Understand gambling</a></h2>
      <p class="section-lead">
        Clear, judgment-free information about gambling and gambling harm.
      </p>
      <ul class="card-grid">
        {
          learnTopics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Family & Friends -->
  <section class="section section-alt" aria-labelledby="family-heading">
    <div class="container">
      <h2 id="family-heading"><a class="section-link" href="/family-and-friends">Family &amp; friends</a></h2>
      <p class="section-lead">
        Worried about someone's gambling? How to understand the risk and talk
        with them — by who you're concerned about.
      </p>
      <ul class="card-grid">
        {
          familyTopics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Professionals -->
  <section class="section" aria-labelledby="pro-heading">
    <div class="container">
      <h2 id="pro-heading"><a class="section-link" href="/professionals">Professionals</a></h2>
      <p class="section-lead">
        Practical ways to bring problem gambling prevention into your work — by
        profession.
      </p>
      <ul class="card-grid">
        {
          professionalsTopics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <style>
    .section-lead {
      font-size: var(--fs-lead);
      max-width: 60ch;
      margin-bottom: var(--space-6);
    }
    /* Section headings double as links to their hub — styled as the heading */
    .section-link {
      color: inherit;
      text-decoration: none;
    }
    .section-link:hover {
      color: var(--c-primary);
    }

    /* Find Your State: map beside the picker */
    .state-finder {
      display: grid;
      gap: var(--space-6);
      align-items: center;
    }
    @media (min-width: 48em) {
      .state-finder {
        grid-template-columns: 1.4fr 1fr;
      }
    }
    @media (max-width: 47.99em) {
      .state-finder__map {
        display: none;
      }
    }

    /* Hero */
    .hero {
      padding-block: var(--space-12) var(--space-10);
      background: var(--c-bg);
    }
    .hero__eyebrow {
      margin: 0 0 var(--space-4);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--c-link);
      font-size: 0.9rem;
    }
    .hero__headline {
      max-width: 18ch;
      margin-bottom: var(--space-5);
    }
    .hero__subhead {
      font-size: 1.25rem;
      max-width: 52ch;
      color: var(--c-text);
      margin-bottom: var(--space-6);
    }
    .hero__finder {
      margin-top: var(--space-2);
    }
  </style>
</BaseLayout>
