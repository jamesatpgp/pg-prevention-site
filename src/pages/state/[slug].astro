      font-size: 0.85rem;
      color: var(--c-text-muted);
      max-width: 70ch;
    }

    /* Regulators */
    .reg-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    }
    .reg-list--sub {
