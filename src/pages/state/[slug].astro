---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";
import fs from "node:fs";
import path from "node:path";
import {
  getAllJurisdictions,
  getJurisdiction,
  getCampaignsForJurisdiction,
  firstSentence,
  agencyKey,
  getPrevalenceForJurisdiction,
  prevalencePlainSummary,
  prevalenceCaption,
  prevalenceCardHeading,
  type LegalStatus,
} from "../../lib/jurisdictions";

export async function getStaticPaths() {
  return getAllJurisdictions().map((j) => ({ params: { slug: j.slug } }));
}

const { slug } = Astro.params;
const j = getJurisdiction(slug!);
if (!j) return Astro.redirect("/find-your-state");

const statusLabel: Record<LegalStatus, string> = {
  authorized: "Authorized",
  limited: "Limited / unsettled",
  "tribal-only": "Tribal only",
  "not-authorized": "Not authorized",
};

const hasPrevention =
  j.help.affiliateName ||
  j.help.preventionOrg ||
  j.help.affiliateUrl;

// Derived structural stats (real archive data; population stats are a gap).
const authorizedCount = j.legal.filter((v) => v.status === "authorized").length;
// Only reference forms the state actually has — hide "not authorized".
const shownForms = j.legal.filter((v) => v.status !== "not-authorized");
// Authorized types with a statute citation, for the regulation-process view.
const processItems = j.legal.filter(
  (v) => v.status === "authorized" && v.citation && v.id !== "tribal",
);
// Group authorized forms by their regulator so a shared agency is shown once
// (laws stay separated; the regulator endpoint is combined).
type ProcGroup = { agency: string | null; url: string | null; items: typeof processItems };
const regGroups: ProcGroup[] = [];
const regSeen = new Map<string, ProcGroup>();
for (const v of processItems) {
  const key = agencyKey(v.agency);
  let g = regSeen.get(key);
  if (!g) {
    g = { agency: v.agency ?? null, url: v.agencyUrl ?? null, items: [] };
    regSeen.set(key, g);
    regGroups.push(g);
  }
  if (!g.url && v.agencyUrl) g.url = v.agencyUrl;
  g.items.push(v);
}
const tribalAuthorized = j.legal.find((v) => v.id === "tribal")?.status === "authorized";

// (At-a-glance stats removed per James — counts moved into the new top-block
// sidebar via the legal-forms list and regulators list.)

// Self-exclusion: enrollable programs vs. documented "no program" findings.
const sePrograms = j.selfExclusion.programs;
const seNoProgram = j.selfExclusion.noProgramFindings;

// ---- New top block: history + state resources + seal ----
// History is now tight enough to render (no embedded revenue figures).
const historyEntry = await getEntry("history", j.slug);
const HistoryContent = historyEntry
  ? (await render(historyEntry)).Content
  : null;

// State prevention campaigns (umbrella / prevention / responsible_gambling only —
// helpline + treatment rows are filtered out at the lib layer per site policy).
const campaigns = getCampaignsForJurisdiction(j.name);
const umbrellaCampaign =
  campaigns.find((c) => c.category === "umbrella") ?? null;

// Non-umbrella campaigns shown as cards below the umbrella narrative.
const otherCampaigns = umbrellaCampaign
  ? campaigns.filter((c) => c !== umbrellaCampaign)
  : campaigns;

// State seal image: SVG preferred, PNG fallback. Renders only when on disk.
const publicSealsDir = path.resolve(process.cwd(), "public/seals");
const sealHit = ["svg", "png"]
  .map((ext) => ({ ext, abs: path.join(publicSealsDir, `${j.slug}.${ext}`) }))
  .find((s) => {
    try {
      return fs.existsSync(s.abs);
    } catch {
      return false;
    }
  });
const sealSrc = sealHit ? `/seals/${j.slug}.${sealHit.ext}` : null;

// State prevalence (youth + adult). Render only when a record exists for
// this jurisdiction. Territories with stat_type "no data" on both measures
// degrade to a single prose block (no card scaffolding).
const prevalence = getPrevalenceForJurisdiction(j.name);
const prevalenceIsTerritory =
  prevalence?.youth?.stat_type === "no data" &&
  prevalence?.adult?.stat_type === "no data";
---

<BaseLayout
  title={`Gambling in ${j.name}`}
  description={`Helplines, who regulates gambling, what's legal, and where to find help in ${j.name}. The National Problem Gambling Helpline is 1-800-MY-RESET.`}
>
  <div class="container breadcrumb">
    <a href="/find-your-state">← All states &amp; territories</a>
  </div>

  <!-- 1. Top block: history + resources (left) · seal + legal forms (right) -->
  <section class="state-top">
    <div class="container state-top__grid">
      <div class="state-top__main">
        <p class="state-top__eyebrow">Gambling in {j.name}</p>
        <h1 class="state-top__title">{j.name}</h1>

        {
          HistoryContent && (
            <div class="state-top__history">
              <HistoryContent />
            </div>
          )
        }

        <section class="state-top__resources" aria-labelledby="resources-h">
          <h2 id="resources-h" class="state-top__h2">
            Prevention resources in {j.name}
          </h2>
          {
            umbrellaCampaign && umbrellaCampaign.blurb ? (
              <article class="state-top__umbrella">
                <p class="state-top__umbrella-blurb">{umbrellaCampaign.blurb}</p>
                <p class="state-top__umbrella-cta">
                  <a href={umbrellaCampaign.url} rel="noopener">
                    Visit {umbrellaCampaign.name} →
                  </a>
                </p>
              </article>
            ) : campaigns.length > 0 ? (
              <p class="lead">
                Recognized prevention programs and campaigns in {j.name}:
              </p>
            ) : (
              <p class="lead">
                {j.name} does not currently have a recognized statewide
                problem-gambling prevention campaign on file.
              </p>
            )
          }
          {
            otherCampaigns.length > 0 && (
              <ul class="campaign-grid">
                {otherCampaigns.map((c) => {
                  const blurb = firstSentence(c.blurb);
                  return (
                    <li>
                      <a class="campaign-card" href={c.url} rel="noopener">
                        <span class="campaign-card__title">{c.name} →</span>
                        {blurb && (
                          <span class="campaign-card__blurb">{blurb}</span>
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )
          }
        </section>
      </div>

      <aside class="state-top__aside">
        {
          sealSrc && (
            <figure class="state-seal-wrap">
              <img
                class="state-seal"
                src={sealSrc}
                alt={`${j.name} state seal`}
                width="240"
                height="240"
              />
            </figure>
          )
        }

        <section class="legal-card" aria-labelledby="legal-card-h">
          <h2 id="legal-card-h" class="legal-card__h">
            Legal gambling in {j.name}
          </h2>
          {
            shownForms.length > 0 ? (
              <ul class="legal-card__list">
                {shownForms.map((v) => (
                  <li class={`legal-card__item legal-card__item--${v.status}`}>
                    <span class="legal-card__label">{v.label}</span>
                    <span class="legal-card__status">
                      {v.year
                        ? `${statusLabel[v.status]} since ${v.year}`
                        : statusLabel[v.status]}
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="legal-card__none">
                No form of gambling is currently authorized.
              </p>
            )
          }
        </section>

        {
          j.regulators.primary.length > 0 && (
            <section class="legal-card" aria-labelledby="regulators-card-h">
              <h2 id="regulators-card-h" class="legal-card__h">
                Regulators in {j.name}
              </h2>
              <ul class="regulators-list">
                {j.regulators.primary.map((r) => (
                  <li>
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </aside>
    </div>
  </section>

  <!-- At-a-glance stats and "Gambling in [State]" summary intentionally removed:
       the new top block above provides the same context via the history narrative,
       the sidebar legal-forms list, and the sidebar regulators list. -->

  <!-- Legal gambling types: moved into the right sidebar of the top block above.
       Statute citations remain visible in the regulation-process section below. -->

  <!-- 4. How gambling is regulated (the process) -->
  <section class="section" aria-labelledby="reg-h">
    <div class="container">
      <h2 id="reg-h">How gambling is regulated in {j.name}</h2>
      <p class="lead">
        Each legal form of gambling moves through the same layered process: a
        <strong>statute</strong> in the state code authorizes it,
        <strong>administrative rules</strong> spell out the details, and a
        <strong>commission or agency</strong> licenses and enforces it.
      </p>

      {
        regGroups.length > 0 && (
          <ol class="process-list">
            {regGroups.flatMap((g) =>
              g.items.map((v) => (
                <li class="process">
                  <p class="process__type">
                    {v.year ? `${v.label} · since ${v.year}` : v.label}
                  </p>
                  <ol class="process__chain">
                    <li class="proc">
                      <span class="proc__step">Law</span>
                      <span class="proc__body">
                        {v.url ? <a href={v.url}>{v.citation}</a> : v.citation}
                      </span>
                    </li>
                    <li class:list={["proc", !v.adminCodeVerified && "proc--pending"]}>
                      <span class="proc__step">Rules</span>
                      <span class="proc__body">
                        {v.adminCodeVerified && v.adminCodeCitation ? (
                          v.adminCodeUrl ? (
                            <a href={v.adminCodeUrl}>{v.adminCodeCitation}</a>
                          ) : (
                            v.adminCodeCitation
                          )
                        ) : (
                          "Not separately codified"
                        )}
                      </span>
                    </li>
                    <li class="proc proc--regulator">
                      <span class="proc__step">Regulator</span>
                      <span class="proc__body">
                        {g.url ? (
                          <a href={g.url}>{g.agency ?? "—"}</a>
                        ) : (
                          (g.agency ?? "—")
                        )}
                      </span>
                    </li>
                  </ol>
                </li>
              )),
            )}
          </ol>
        )
      }

      {
        tribalAuthorized && (
          <p class="tribal-note">
            Tribal gaming is regulated under federal law (the Indian Gaming
            Regulatory Act) through the National Indian Gaming Commission and
            tribal–state compacts, with {j.regulators.tribalCount} tribal gaming
            commission{j.regulators.tribalCount === 1 ? "" : "s"} on file (listed
            below).
          </p>
        )
      }

      {
        (j.regulators.tribalCount > 0 || j.regulators.county.length > 0) && (
          <details class="reg-more">
            <summary>
              Show tribal and county regulators
              {j.regulators.tribalCount > 0
                ? ` (${j.regulators.tribalCount} tribal gaming commission${j.regulators.tribalCount === 1 ? "" : "s"})`
                : ""}
            </summary>
            <ul class="reg-list reg-list--sub">
              {j.regulators.county.map((r) => (
                <li class="reg-item">
                  <p class="reg-item__name">
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </p>
                  <p class="reg-item__type">{r.type}</p>
                </li>
              ))}
              {j.regulators.tribal.map((r) => (
                <li class="reg-item">
                  <p class="reg-item__name">
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </p>
                  <p class="reg-item__type">{r.type}</p>
                </li>
              ))}
            </ul>
          </details>
        )
      }
    </div>
  </section>

  <!-- Prevalence: youth + adult, never side-by-side, with firebreak. -->
  {
    prevalence && (
      <section class="section state-prevalence" aria-labelledby="prev-h">
        <div class="container state-prevalence__container">
          {prevalenceIsTerritory ? (
            <>
              <h2 id="prev-h">Gambling prevalence data for {j.name}</h2>
              <p class="lead">{prevalence.snippets.body}</p>
            </>
          ) : (
            <>
              <h2 id="prev-h">What we know about gambling in {j.name}</h2>
              <p class="lead">
                Two different things get measured here. The teen number is about
                how many young people gambled at all. The adult number is about
                whether adults have problems with gambling. We show them apart.
              </p>

              <div class="prev-grid">
                <article class="prev-card prev-card--youth">
                  <h3>{prevalenceCardHeading("youth", prevalence, j.name)}</h3>
                  <p class="prev-summary">
                    {prevalencePlainSummary("youth", prevalence, j.name)}
                  </p>
                  <p class="prev-caption">{prevalenceCaption(prevalence.youth)}</p>
                  <details class="prev-disclosure">
                    <summary>See the source and methodology</summary>
                    <p>{prevalence.snippets.youth_sentence}</p>
                    {prevalence.youth.source_url && (
                      <p class="prev-source">
                        <a href={prevalence.youth.source_url} rel="noopener">
                          {prevalence.youth.source}, {prevalence.youth.year} →
                        </a>
                      </p>
                    )}
                  </details>
                </article>

                <article class="prev-card prev-card--adult">
                  <h3>{prevalenceCardHeading("adult", prevalence, j.name)}</h3>
                  <p class="prev-summary">
                    {prevalencePlainSummary("adult", prevalence, j.name)}
                  </p>
                  <p class="prev-caption">{prevalenceCaption(prevalence.adult)}</p>
                  <details class="prev-disclosure">
                    <summary>See the source and methodology</summary>
                    <p>{prevalence.snippets.adult_sentence}</p>
                    {prevalence.adult.source_url && (
                      <p class="prev-source">
                        <a href={prevalence.adult.source_url} rel="noopener">
                          {prevalence.adult.source}, {prevalence.adult.year} →
                        </a>
                      </p>
                    )}
                  </details>
                </article>
              </div>

              <p class="prev-firebreak">
                These two numbers measure different things and cannot be
                compared, added, or averaged. The teen number is about whether
                young people gambled at all. The adult number is about whether
                adults are having problems with gambling.
              </p>
            </>
          )}
        </div>
      </section>
    )
  }

  <!-- 5. Get help in [State] -->
  <section class="section section-alt" aria-labelledby="help-h">
    <div class="container">
      <h2 id="help-h">Problem gambling organizations in {j.name}</h2>
      {
        hasPrevention ? (
          <ul class="help-list">
            {(j.help.affiliateName || j.help.affiliateUrl) && (
              <li>
                <strong>NCPG affiliate:</strong>{" "}
                {j.help.affiliateUrl ? (
                  <a href={j.help.affiliateUrl}>{j.help.affiliateName ?? j.help.affiliateUrl}</a>
                ) : (
                  j.help.affiliateName
                )}
              </li>
            )}
            {j.help.preventionOrg && j.help.preventionOrg !== j.help.affiliateName && (
              <li>
                <strong>Prevention:</strong>{" "}
                {j.help.preventionUrl ? (
                  <a href={j.help.preventionUrl}>{j.help.preventionOrg}</a>
                ) : (
                  j.help.preventionOrg
                )}
              </li>
            )}
          </ul>
        ) : (
          <p>
            No state-specific organization is listed for {j.name} yet. The
            national helpline above is available any time.
          </p>
        )
      }
    </div>
  </section>

  <!-- 6. Resources (Phase 4 placeholder) -->
  <section class="section" aria-labelledby="res-h">
    <div class="container">
      <h2 id="res-h">Resources for {j.name}</h2>
      <p class="coming">
        Downloadable rack cards and fact sheets customized for {j.name} are
        coming soon. In the meantime, browse the{" "}
        <a href="/resources">Resource Library</a>.
      </p>
    </div>
  </section>

  <!-- 7. Self-exclusion -->
  <section class="section section-alt" aria-labelledby="se-h">
    <div class="container">
      <h2 id="se-h">Self-exclusion in {j.name}</h2>
      <p class="lead">
        Self-exclusion is a free, voluntary way to ban yourself from gambling.
        You add your name to a list, and operators must turn you away and stop
        sending you offers for the time you choose.
      </p>

      {
        sePrograms.length > 0 ? (
          <ul class="se-list">
            {sePrograms.map((p) => (
              <li class="se-card">
                <div class="se-card__head">
                  <h3 class="se-card__name">
                    {p.url ? <a href={p.url}>{p.name}</a> : p.name}
                  </h3>
                  <span class="se-badge">{p.typeLabel}</span>
                </div>
                <dl class="se-meta">
                  {p.verticals && (
                    <div class="se-meta__row">
                      <dt>Covers</dt>
                      <dd>{p.verticals}</dd>
                    </div>
                  )}
                  {p.body && (
                    <div class="se-meta__row">
                      <dt>Run by</dt>
                      <dd>{p.body}</dd>
                    </div>
                  )}
                  {p.enrollment && (
                    <div class="se-meta__row">
                      <dt>How to enroll</dt>
                      <dd>{p.enrollment}</dd>
                    </div>
                  )}
                  {p.duration && (
                    <div class="se-meta__row">
                      <dt>How long</dt>
                      <dd>{p.duration}</dd>
                    </div>
                  )}
                  {p.removal && (
                    <div class="se-meta__row">
                      <dt>Coming off the list</dt>
                      <dd>{p.removal}</dd>
                    </div>
                  )}
                </dl>
                {p.idpairFlag && (
                  <p class="se-note">
                    This enrollment is powered by idPair's National Voluntary
                    Self-Exclusion Program (NVSEP), which can extend your
                    exclusion across participating states.
                  </p>
                )}
              </li>
            ))}
          </ul>
        ) : authorizedCount === 0 ? (
          <p>
            {j.name} has no legal gambling, so there is no self-exclusion program
            on file. If online or out-of-state gambling is affecting you, you can
            still get free, confidential help — call or text{" "}
            <a href={`tel:${j.helpline.national.tel}`}>{j.helpline.national.label}</a>.
          </p>
        ) : (
          <p>
            We could not confirm a statewide self-exclusion list in {j.name}.
            Individual casinos, sportsbooks, or apps may still let you exclude
            yourself — ask the operator directly. To talk through your options,
            call or text{" "}
            <a href={`tel:${j.helpline.national.tel}`}>{j.helpline.national.label}</a>.
          </p>
        )
      }

      {
        sePrograms.length > 0 && seNoProgram.length > 0 && (
          <details class="se-more">
            <summary>
              Gambling types without a self-exclusion program ({seNoProgram.length})
            </summary>
            <ul class="se-none-list">
              {seNoProgram.map((p) => (
                <li>
                  {p.url ? <a href={p.url}>{p.name}</a> : p.name}
                  {p.verticals ? ` — ${p.verticals}` : ""}
                </li>
              ))}
            </ul>
          </details>
        )
      }

      {
        sePrograms.length > 0 && (
          <p class="fine-print">
            Based on our self-exclusion inventory
            {j.selfExclusion.retrievalDate ? `, retrieved ${j.selfExclusion.retrievalDate}` : ""}.
            Follow each link for the official program and current terms.
          </p>
        )
      }
    </div>
  </section>

  <!-- Funding & transparency intentionally omitted for now: no revenue /
       taxation / funding figures until that content is handled deliberately.
       The funding data is retained in the archive + data layer. -->

  <!-- Brief history is now rendered in the top block above (sourced from
       src/data/history/<slug>.md). Old archival narratives were rewritten into
       tight ~230-word summaries with no embedded revenue figures. -->

  <style>
    .breadcrumb {
      padding-top: var(--space-5);
    }
    .breadcrumb a {
      font-weight: 600;
    }

    /* Top block: history + resources (left) · seal + legal-forms (right) */
    .state-top {
      padding-block: var(--space-7) var(--space-6);
    }
    .state-top__grid {
      display: grid;
      gap: var(--space-7);
    }
    @media (min-width: 56em) {
      .state-top__grid {
        grid-template-columns: 1fr 16rem;
        gap: var(--space-8);
        align-items: start;
      }
    }
    .state-top__main {
      min-width: 0;
    }
    .state-top__eyebrow {
      margin: 0;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--c-link);
      font-size: 0.85rem;
    }
    .state-top__title {
      margin: var(--space-2) 0 var(--space-5);
    }
    .state-top__history {
      margin-bottom: var(--space-7);
    }
    .state-top__history :global(p) {
      margin-bottom: var(--space-4);
      line-height: 1.65;
      max-width: 70ch;
    }
    .state-top__history :global(p):last-child {
      margin-bottom: 0;
    }
    .state-top__h2 {
      margin: 0 0 var(--space-3);
    }
    .state-top__resources .lead {
      margin-bottom: var(--space-5);
    }

    /* Campaign cards (left column) */
    .campaign-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: var(--space-3);
    }
    .campaign-card {
      display: block;
      padding: var(--space-4) var(--space-5);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s ease;
    }
    .campaign-card:hover,
    .campaign-card:focus-visible {
      border-color: var(--c-primary);
      outline: none;
    }
    .campaign-card__title {
      display: block;
      font-weight: 700;
      color: var(--c-link);
      margin-bottom: var(--space-1);
    }
    .campaign-card__blurb {
      display: block;
      font-size: 0.95rem;
      color: var(--c-text);
      line-height: 1.5;
    }

    /* Umbrella narrative paragraph (replaces the one-sentence intro). */
    .state-top__umbrella {
      margin: 0 0 var(--space-5);
    }
    .state-top__umbrella-blurb {
      font-size: 1.05rem;
      line-height: 1.65;
      max-width: 70ch;
      margin: 0 0 var(--space-3);
      color: var(--c-text);
    }
    .state-top__umbrella-cta {
      margin: 0;
    }
    .state-top__umbrella-cta a {
      font-weight: 700;
      color: var(--c-link);
      text-decoration: none;
    }
    .state-top__umbrella-cta a:hover,
    .state-top__umbrella-cta a:focus-visible {
      text-decoration: underline;
    }

    /* Sidebar: seal + legal-forms card */
    .state-top__aside {
      display: grid;
      gap: var(--space-5);
    }
    @media (max-width: 55.99em) {
      /* On narrow viewports, surface the seal+legal card ABOVE the history. */
      .state-top__grid .state-top__main { order: 2; }
      .state-top__grid .state-top__aside { order: 1; }
    }
    .state-seal-wrap {
      margin: 0;
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      display: grid;
      place-items: center;
    }
    /* Every seal renders in a uniform square slot regardless of its SVG's
       intrinsic aspect ratio. Tall seals (CT oval, Guam ovoid) and wide ones
       (OK) get whitespace on the off-axis but match the others in slot size. */
    .state-seal {
      display: block;
      width: 100%;
      max-width: 11rem;
      aspect-ratio: 1 / 1;
      object-fit: contain;
    }

    .lead {
      font-size: 1.2rem;
      max-width: 70ch;
    }

    /* At-a-glance stats removed (section gone). */

    /* Regulation process — chain row: Law → Rules → Regulator (same height by grid). */
    .process-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      margin: var(--space-6) 0;
      padding: 0;
    }
    .process {
      padding: var(--space-5);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-left: 4px solid var(--c-primary);
      border-radius: var(--radius-lg);
    }
    .process__type {
      margin: 0 0 var(--space-3);
      font-weight: 800;
      color: var(--c-heading);
      font-size: 1.1rem;
    }
    .process__chain {
      list-style: none;
      display: grid;
      gap: var(--space-3);
      margin: 0;
      padding: 0;
    }
    @media (min-width: 48em) {
      .process__chain {
        grid-template-columns: 1fr 1fr 1fr;
        align-items: stretch;
      }
    }
    /* Regulator cell: distinct tinted background, same grid row as Law/Rules. */
    .proc--regulator {
      background: var(--c-primary-tint);
    }
    .proc--regulator .proc__body a {
      color: var(--c-link);
      font-weight: 700;
    }
    .proc {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
      padding: var(--space-3);
      background: var(--c-surface-alt);
      border-radius: var(--radius);
      position: relative;
    }
    .proc--pending {
      background: transparent;
      border: 1px dashed var(--c-border-strong);
    }
    .proc__step {
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--c-primary);
    }
    .proc--pending .proc__step {
      color: var(--c-text-muted);
    }
    .proc__body {
      font-size: 0.95rem;
      word-break: break-word;
    }
    /* Connector arrows between steps (decorative) */
    @media (min-width: 48em) {
      .proc + .proc::before {
        content: "→";
        position: absolute;
        left: calc(var(--space-3) * -1 - 0.4em);
        top: 50%;
        transform: translateY(-50%);
        color: var(--c-border-strong);
        font-weight: 800;
      }
    }
