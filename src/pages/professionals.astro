---
import BaseLayout from "../layouts/BaseLayout.astro";

const audiences = [
  { title: "Prevention Specialists", body: "How credentialed prevention specialists can build problem gambling into their prevention work.", href: "/professionals/prevention-specialists" },
  { title: "Treatment Providers", body: "How treatment providers can incorporate problem gambling prevention into their practice.", href: "/professionals/treatment-providers" },
  { title: "Healthcare Providers", body: "How doctors, dentists, and other clinicians can work prevention into routine care.", href: "/professionals/healthcare-providers" },
  { title: "Teachers", body: "How educators can bring problem gambling prevention into the classroom.", href: "/professionals/teachers" },
];
---

<BaseLayout
  title="Professionals"
  description="How prevention specialists, treatment providers, healthcare providers, and teachers can bring problem gambling prevention into their work."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">By profession</p>
      <h1>Professionals</h1>
      <p class="page-header__lead">
        How to bring problem gambling prevention into your work — organized by
        profession. Choose the role that fits you.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          audiences.map((a) => (
            <li>
              <a class="card-link" href={a.href}>
                <span class="card-link__title">{a.title}</span>
                <span>{a.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p style="margin-top: var(--space-6); font-weight: 700;">
        <a href="/resources">Browse the Resource Library →</a>
      </p>
    </div>
  </section>
</BaseLayout>
