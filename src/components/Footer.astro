---
const year = new Date().getFullYear();

const quickLinks = [
  { label: "Sitemap", href: "/sitemap" },
  { label: "Accessibility statement", href: "/accessibility" },
  { label: "Privacy", href: "/privacy" },
  { label: "Sponsors & partners", href: "/sponsors" },
];
---

<footer class="site-footer surface-dark">
  <div class="container footer-grid">
    <nav class="footer-links" aria-label="Footer">
      <h2 class="footer-heading">Site</h2>
      <ul>
        {
          quickLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer-sponsors">
      <h2 class="footer-heading">Sponsors</h2>
      <a class="sponsor-placeholder" href="mailto:james@pgprevention.com">
        <span>Your Logo Here</span>
      </a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="footer-copyright">
      &copy; {year} Problem Gambling Prevention. Information you can trust about
      gambling and gambling harm.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-band-pro-bg);
    color: #fff;
    padding-block: var(--space-8) var(--space-6);
    margin-top: var(--space-12);
  }

  .footer-grid {
    display: grid;
    gap: var(--space-8);
  }

  @media (min-width: 48em) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .footer-heading {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-band-pro-muted);
    margin-bottom: var(--space-3);
  }

  /* Links */
  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .footer-links a {
    display: inline-block;
    min-height: var(--target-min);
    padding-block: var(--space-2);
    color: var(--c-band-pro-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .footer-links a:hover {
    color: #fff;
  }

  /* Sponsor placeholder */
  .sponsor-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    border: 2px dashed var(--c-band-pro-muted);
    border-radius: var(--radius);
    color: var(--c-band-pro-muted);
    font-size: 0.85rem;
    text-decoration: none;
  }
  .sponsor-placeholder:hover {
    border-color: #fff;
    color: #fff;
  }
  .footer-bottom {
    margin-top: var(--space-8);
    padding-top: var(--space-5);
    border-top: 1px solid var(--c-band-pro-border);
  }
  .footer-copyright {
    margin: 0;
    font-size: 0.85rem;
    color: var(--c-band-pro-muted);
    max-width: none;
  }
</style>
