---
import BaseLayout from "../layouts/BaseLayout.astro";
import HelpCallout from "../components/HelpCallout.astro";

const audiences = [
  { title: "Youth", body: "Gambling-harm information for youth and the adults who support them.", href: "/family-and-friends/youth" },
  { title: "Young Adults", body: "For young adults — a group facing higher risk as betting spreads.", href: "/family-and-friends/young-adults" },
  { title: "Older Adults", body: "For older adults and the families who support them.", href: "/family-and-friends/older-adults" },
  { title: "Veterans", body: "Gambling-harm resources for those who have served.", href: "/family-and-friends/veterans" },
];
---

<BaseLayout
  title="Family & Friends"
  description="Support and information for the people around someone affected by gambling — parents, adult children, friends, and veterans."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Family &amp; friends</p>
      <h1>Family &amp; friends</h1>
      <p class="page-header__lead">
        Gambling harm shows up differently across life stages and communities.
        These pages gather information for specific groups — and the family and
        friends who support them.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          audiences.map((a) => (
            <li>
              <a class="card-link" href={a.href}>
                <span class="card-link__title">{a.title}</span>
                <span>{a.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <HelpCallout />
    </div>
  </section>
</BaseLayout>
