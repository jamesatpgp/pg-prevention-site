---
import BaseLayout from "../layouts/BaseLayout.astro";

const topics = [
  { title: "Strategic Prevention Framework", body: "TBD.", href: "/understand-prevention/strategic-prevention-framework" },
  { title: "Strategies", body: "TBD.", href: "/understand-prevention/strategies" },
  { title: "Coalitions", body: "TBD.", href: "/understand-prevention/coalitions" },
  { title: "Comorbidities", body: "TBD.", href: "/understand-prevention/comorbidities" },
];
---

<BaseLayout
  title="Understand Prevention"
  description="Plain-language information about problem gambling prevention — what it is, how it works, and who does the work."
>
  <header class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Public education</p>
      <h1>Understand prevention</h1>
      <p class="page-header__lead">
        Clear, judgment-free information about problem gambling prevention.
        <em>[Section content in development.]</em>
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <ul class="card-grid">
        {
          topics.map((t) => (
            <li>
              <a class="card-link" href={t.href}>
                <span class="card-link__title">{t.title}</span>
                <span>{t.body}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
