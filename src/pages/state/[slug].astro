---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllJurisdictions,
  getJurisdiction,
  type LegalStatus,
} from "../../lib/jurisdictions";

export async function getStaticPaths() {
  return getAllJurisdictions().map((j) => ({ params: { slug: j.slug } }));
}

const { slug } = Astro.params;
const j = getJurisdiction(slug!);
if (!j) return Astro.redirect("/find-your-state");

const statusLabel: Record<LegalStatus, string> = {
  authorized: "Authorized",
  limited: "Limited / unsettled",
  "tribal-only": "Tribal only",
  "not-authorized": "Not authorized",
};

const hasPrevention =
  j.help.affiliateName ||
  j.help.preventionOrg ||
  j.help.treatmentDirectoryUrl ||
  j.help.affiliateUrl;

// Derived structural stats (real archive data; population stats are a gap).
const authorizedCount = j.legal.filter((v) => v.status === "authorized").length;
// Only reference forms the state actually has — hide "not authorized".
const shownForms = j.legal.filter((v) => v.status !== "not-authorized");
const years = j.legal
  .map((v) => (v.year ? parseInt(v.year, 10) : null))
  .filter((y): y is number => y !== null && !Number.isNaN(y));
const earliestYear = years.length ? Math.min(...years) : null;
// Authorized types with a statute citation, for the regulation-process view.
const processItems = j.legal.filter(
  (v) => v.status === "authorized" && v.citation && v.id !== "tribal",
);
// Group authorized forms by their regulator so a shared agency is shown once
// (laws stay separated; the regulator endpoint is combined).
type ProcGroup = { agency: string | null; url: string | null; items: typeof processItems };
const regGroups: ProcGroup[] = [];
const regSeen = new Map<string, ProcGroup>();
for (const v of processItems) {
  const key = (v.agency ?? "").trim().toLowerCase() || "__none__";
  let g = regSeen.get(key);
  if (!g) {
    g = { agency: v.agency ?? null, url: v.agencyUrl ?? null, items: [] };
    regSeen.set(key, g);
    regGroups.push(g);
  }
  if (!g.url && v.agencyUrl) g.url = v.agencyUrl;
  g.items.push(v);
}
const tribalAuthorized = j.legal.find((v) => v.id === "tribal")?.status === "authorized";

// At-a-glance stats: drop any zero/empty value (don't surface nil counts).
const glanceItems = (
  [
    { num: authorizedCount, one: "gambling type authorized", many: "gambling types authorized" },
    { num: j.regulators.primary.length, one: "state-level regulator", many: "state-level regulators" },
    { num: j.regulators.tribalCount, one: "tribal gaming commission", many: "tribal gaming commissions" },
    { num: earliestYear, one: "earliest authorization", many: "earliest authorization" },
  ] as { num: number | null; one: string; many: string }[]
).filter((s) => s.num != null && s.num > 0);

// Self-exclusion: enrollable programs vs. documented "no program" findings.
const sePrograms = j.selfExclusion.programs;
const seNoProgram = j.selfExclusion.noProgramFindings;
---

<BaseLayout
  title={`Gambling in ${j.name}`}
  description={`Helplines, who regulates gambling, what's legal, and where to find help in ${j.name}. The National Problem Gambling Helpline is 1-800-MY-RESET.`}
>
  <div class="container breadcrumb">
    <a href="/find-your-state">← All states &amp; territories</a>
  </div>

  <!-- 1. Helpline banner -->
  <section class="helpline-banner" aria-label={`Get help in ${j.name}`}>
    <div class="container">
      <h1>{j.name}</h1>
      <div class="helpline-grid">
        <a
          class="helpline-card helpline-card--national"
          href={`tel:${j.helpline.national.tel}`}
        >
          <img
            class="myreset-lockup"
            src="/brand/myreset-horizontal-color.png"
            width="640"
            height="162"
            alt="Call or text 1-800-MY-RESET, the National Problem Gambling Helpline"
          />
        </a>

        <a class="helpline-card helpline-card--988" href="tel:988">
          <img
            class="lifeline-988-logo"
            src="/brand/988-horizontal-navy.png"
            width="640"
            height="124"
            alt="Call or text 988, the Suicide & Crisis Lifeline"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- At a glance (structural stats) -->
  <section class="section glance-section" aria-labelledby="glance-h">
    <div class="container">
      <h2 id="glance-h" class="visually-hidden">{j.name} at a glance</h2>
      {
        glanceItems.length > 0 && (
          <ul class="glance">
            {glanceItems.map((s) => (
              <li class="glance__item">
                <span class="glance__num">{s.num}</span>
                <span class="glance__label">{s.num === 1 ? s.one : s.many}</span>
              </li>
            ))}
          </ul>
        )
      }
      <p class="fine-print">
        Adult and youth prevalence data for {j.name} is coming soon.
      </p>
    </div>
  </section>

  <!-- 2. Gambling in [State] -->
  {
    j.summary && (
      <section class="section" aria-labelledby="summary-h">
        <div class="container">
          <h2 id="summary-h">Gambling in {j.name}</h2>
          <p class="lead">{j.summary}</p>
        </div>
      </section>
    )
  }

  <!-- 3. Legal gambling types -->
  <section class="section section-alt" aria-labelledby="legal-h">
    <div class="container">
      <h2 id="legal-h">What kinds of gambling are legal in {j.name}?</h2>
      {
        shownForms.length > 0 ? (
          <ul class="legal-grid">
            {shownForms.map((v) => (
              <li class={`legal-cell legal-cell--${v.status}`}>
                <span class="legal-cell__status" aria-hidden="true">
                  {v.status === "authorized" ? "✓" : "•"}
                </span>
                <span class="legal-cell__label">{v.label}</span>
                <span class="legal-cell__state">
                  {v.year ? `${statusLabel[v.status]} (since ${v.year})` : statusLabel[v.status]}
                </span>
                {v.citation && (
                  <span class="legal-cell__cite">
                    {v.url ? <a href={v.url}>{v.citation}</a> : v.citation}
                  </span>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="lead">
            No form of gambling is currently authorized in {j.name}. People in
            {j.name} can still experience gambling harm — including from online or
            out-of-state activity — and free help is always available.
          </p>
        )
      }
      <p class="fine-print">
        Based on our statute inventory{j.retrievalDate ? `, retrieved ${j.retrievalDate}` : ""}.
        See each citation for the source.
      </p>
    </div>
  </section>

  <!-- 4. How gambling is regulated (the process) -->
  <section class="section" aria-labelledby="reg-h">
    <div class="container">
      <h2 id="reg-h">How gambling is regulated in {j.name}</h2>
      <p class="lead">
        Each legal form of gambling moves through the same layered process: a
        <strong>statute</strong> in the state code authorizes it,
        <strong>administrative rules</strong> spell out the details, and a
        <strong>commission or agency</strong> licenses and enforces it.
      </p>

      {
        regGroups.length > 0 && (
          <ol class="process-list">
            {regGroups.map((g) => (
              <li class:list={["process", g.items.length > 1 && "process--grouped"]}>
                <div class="process__forms">
                  {g.items.map((v) => (
                    <div class="process__form">
                      <p class="process__type">
                        {v.year ? `${v.label} · since ${v.year}` : v.label}
                      </p>
                      <ol class="process__chain">
                        <li class="proc">
                          <span class="proc__step">Law</span>
                          <span class="proc__body">
                            {v.url ? <a href={v.url}>{v.citation}</a> : v.citation}
                          </span>
                        </li>
                        <li class:list={["proc", !v.adminCodeVerified && "proc--pending"]}>
                          <span class="proc__step">Rules</span>
                          <span class="proc__body">
                            {v.adminCodeVerified && v.adminCodeCitation ? (
                              v.adminCodeUrl ? (
                                <a href={v.adminCodeUrl}>{v.adminCodeCitation}</a>
                              ) : (
                                v.adminCodeCitation
                              )
                            ) : (
                              "Not separately codified"
                            )}
                          </span>
                        </li>
                      </ol>
                    </div>
                  ))}
                </div>
                {g.url ? (
                  <a class="proc proc--regulator proc--reglink" href={g.url}>
                    <span class="proc__step">
                      {g.items.length > 1 ? "Regulator (shared)" : "Regulator"}
                    </span>
                    <span class="proc__body">{g.agency ?? "—"}</span>
                  </a>
                ) : (
                  <div class="proc proc--regulator">
                    <span class="proc__step">
                      {g.items.length > 1 ? "Regulator (shared)" : "Regulator"}
                    </span>
                    <span class="proc__body">{g.agency ?? "—"}</span>
                  </div>
                )}
              </li>
            ))}
          </ol>
        )
      }

      {
        tribalAuthorized && (
          <p class="tribal-note">
            Tribal gaming is regulated under federal law (the Indian Gaming
            Regulatory Act) through the National Indian Gaming Commission and
            tribal–state compacts, with {j.regulators.tribalCount} tribal gaming
            commission{j.regulators.tribalCount === 1 ? "" : "s"} on file (listed
            below).
          </p>
        )
      }

      {
        (j.regulators.tribalCount > 0 || j.regulators.county.length > 0) && (
          <details class="reg-more">
            <summary>
              Show tribal and county regulators
              {j.regulators.tribalCount > 0
                ? ` (${j.regulators.tribalCount} tribal gaming commission${j.regulators.tribalCount === 1 ? "" : "s"})`
                : ""}
            </summary>
            <ul class="reg-list reg-list--sub">
              {j.regulators.county.map((r) => (
                <li class="reg-item">
                  <p class="reg-item__name">
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </p>
                  <p class="reg-item__type">{r.type}</p>
                </li>
              ))}
              {j.regulators.tribal.map((r) => (
                <li class="reg-item">
                  <p class="reg-item__name">
                    {r.website ? <a href={r.website}>{r.name}</a> : r.name}
                  </p>
                  <p class="reg-item__type">{r.type}</p>
                </li>
              ))}
            </ul>
          </details>
        )
      }
    </div>
  </section>

  <!-- 5. Get help in [State] -->
  <section class="section section-alt" aria-labelledby="help-h">
    <div class="container">
      <h2 id="help-h">Get help in {j.name}</h2>
      {
        hasPrevention ? (
          <ul class="help-list">
            {(j.help.affiliateName || j.help.affiliateUrl) && (
              <li>
                <strong>NCPG affiliate:</strong>{" "}
                {j.help.affiliateUrl ? (
                  <a href={j.help.affiliateUrl}>{j.help.affiliateName ?? j.help.affiliateUrl}</a>
                ) : (
                  j.help.affiliateName
                )}
              </li>
            )}
            {j.help.preventionOrg && j.help.preventionOrg !== j.help.affiliateName && (
              <li>
                <strong>Prevention &amp; treatment:</strong>{" "}
                {j.help.preventionUrl ? (
                  <a href={j.help.preventionUrl}>{j.help.preventionOrg}</a>
                ) : (
                  j.help.preventionOrg
                )}
              </li>
            )}
            {j.help.treatmentDirectoryUrl && (
              <li>
                <strong>Find treatment:</strong>{" "}
                <a href={j.help.treatmentDirectoryUrl}>Treatment directory</a>
              </li>
            )}
          </ul>
        ) : (
          <p>
            No state-specific organization is listed for {j.name}. The national
            helpline above and the{" "}
            <a href="https://www.ncpgambling.org/help-treatment/treatment-facilities/">
              NCPG treatment directory
            </a>{" "}
            can still help.
          </p>
        )
      }
    </div>
  </section>

  <!-- 6. Resources (Phase 4 placeholder) -->
  <section class="section" aria-labelledby="res-h">
    <div class="container">
      <h2 id="res-h">Resources for {j.name}</h2>
      <p class="coming">
        Downloadable rack cards and fact sheets customized for {j.name} are
        coming soon. In the meantime, browse the{" "}
        <a href="/resources">Resource Library</a>.
      </p>
    </div>
  </section>

  <!-- 7. Self-exclusion -->
  <section class="section section-alt" aria-labelledby="se-h">
    <div class="container">
      <h2 id="se-h">Self-exclusion in {j.name}</h2>
      <p class="lead">
        Self-exclusion is a free, voluntary way to ban yourself from gambling.
        You add your name to a list, and operators must turn you away and stop
        sending you offers for the time you choose.
      </p>

      {
        sePrograms.length > 0 ? (
          <ul class="se-list">
            {sePrograms.map((p) => (
              <li class="se-card">
                <div class="se-card__head">
                  <h3 class="se-card__name">
                    {p.url ? <a href={p.url}>{p.name}</a> : p.name}
                  </h3>
                  <span class="se-badge">{p.typeLabel}</span>
                </div>
                <dl class="se-meta">
                  {p.verticals && (
                    <div class="se-meta__row">
                      <dt>Covers</dt>
                      <dd>{p.verticals}</dd>
                    </div>
                  )}
                  {p.body && (
                    <div class="se-meta__row">
                      <dt>Run by</dt>
                      <dd>{p.body}</dd>
                    </div>
                  )}
                  {p.enrollment && (
                    <div class="se-meta__row">
                      <dt>How to enroll</dt>
                      <dd>{p.enrollment}</dd>
                    </div>
                  )}
                  {p.duration && (
                    <div class="se-meta__row">
                      <dt>How long</dt>
                      <dd>{p.duration}</dd>
                    </div>
                  )}
                  {p.removal && (
                    <div class="se-meta__row">
                      <dt>Coming off the list</dt>
                      <dd>{p.removal}</dd>
                    </div>
                  )}
                </dl>
                {p.idpairFlag && (
                  <p class="se-note">
                    This enrollment is powered by idPair's National Voluntary
                    Self-Exclusion Program (NVSEP), which can extend your
                    exclusion across participating states.
                  </p>
                )}
              </li>
            ))}
          </ul>
        ) : authorizedCount === 0 ? (
          <p>
            {j.name} has no legal gambling, so there is no self-exclusion program
            on file. If online or out-of-state gambling is affecting you, you can
            still get free, confidential help — call or text{" "}
            <a href={`tel:${j.helpline.national.tel}`}>{j.helpline.national.label}</a>.
          </p>
        ) : (
          <p>
            We could not confirm a statewide self-exclusion list in {j.name}.
            Individual casinos, sportsbooks, or apps may still let you exclude
            yourself — ask the operator directly. To talk through your options,
            call or text{" "}
            <a href={`tel:${j.helpline.national.tel}`}>{j.helpline.national.label}</a>.
          </p>
        )
      }

      {
        sePrograms.length > 0 && seNoProgram.length > 0 && (
          <details class="se-more">
            <summary>
              Gambling types without a self-exclusion program ({seNoProgram.length})
            </summary>
            <ul class="se-none-list">
              {seNoProgram.map((p) => (
                <li>
                  {p.url ? <a href={p.url}>{p.name}</a> : p.name}
                  {p.verticals ? ` — ${p.verticals}` : ""}
                </li>
              ))}
            </ul>
          </details>
        )
      }

      {
        sePrograms.length > 0 && (
          <p class="fine-print">
            Based on our self-exclusion inventory
            {j.selfExclusion.retrievalDate ? `, retrieved ${j.selfExclusion.retrievalDate}` : ""}.
            Follow each link for the official program and current terms.
          </p>
        )
      }
    </div>
  </section>

  <!-- Funding & transparency intentionally omitted for now: no revenue /
       taxation / funding figures until that content is handled deliberately.
       The funding data is retained in the archive + data layer. -->

  <!-- Brief history intentionally hidden for now: the archival narratives
       contain revenue / taxation / funding figures (e.g., PGNO funding amounts)
       that can't be surgically removed from verbatim prose. The history files
       and the `history` content collection are retained; re-enable after a
       figure review. -->

  <style>
    .breadcrumb {
      padding-top: var(--space-5);
    }
    .breadcrumb a {
      font-weight: 600;
    }

    /* Helpline banner */
    .helpline-banner {
      background: var(--c-primary-tint);
      padding-block: var(--space-8);
      border-bottom: 1px solid var(--c-border);
    }
    .helpline-banner h1 {
      margin-bottom: var(--space-5);
    }
    .helpline-grid {
      display: grid;
      gap: var(--space-4);
    }
    @media (min-width: 48em) {
      .helpline-grid {
        grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
      }
    }
    .helpline-card {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      text-decoration: none;
    }
    .helpline-card--national {
      border: 2px solid var(--c-primary);
    }
    .myreset-lockup {
      display: block;
      width: 100%;
      max-width: 15rem;
      height: auto;
    }
    .lifeline-988-logo {
      display: block;
      width: 100%;
      max-width: 12rem;
      height: auto;
    }

    .lead {
      font-size: 1.2rem;
      max-width: 70ch;
    }

    /* At a glance */
    .glance-section {
      padding-block: var(--space-6);
    }
    .glance {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    }
    .glance__item {
      padding: var(--space-4);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      text-align: center;
    }
    .glance__num {
      display: block;
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--c-heading);
      line-height: 1.1;
    }
    .glance__den {
      font-size: 1.2rem;
      color: var(--c-text-muted);
    }
    .glance__label {
      display: block;
      margin-top: var(--space-2);
      color: var(--c-text-muted);
      font-size: 0.9rem;
    }

    /* Regulation process */
    .process-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      margin: var(--space-6) 0;
    }
    .process {
      padding: var(--space-5);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-left: 4px solid var(--c-primary);
      border-radius: var(--radius-lg);
      display: grid;
      gap: var(--space-4);
    }
    @media (min-width: 48em) {
      .process {
        grid-template-columns: 1fr minmax(11rem, 15rem);
        align-items: stretch;
        column-gap: var(--space-5);
      }
    }
    .process__forms {
      display: grid;
      gap: var(--space-4);
      min-width: 0;
    }
    .process__form + .process__form {
      border-top: 1px solid var(--c-border);
      padding-top: var(--space-4);
    }
    .process__type {
      margin: 0 0 var(--space-3);
      font-weight: 800;
      color: var(--c-heading);
      font-size: 1.1rem;
    }
    .process__chain {
      list-style: none;
      display: grid;
      gap: var(--space-3);
    }
    @media (min-width: 48em) {
      .process__chain {
        grid-template-columns: 1fr 1fr;
        align-items: stretch;
      }
    }
    /* Regulator endpoint: shown once per regulator, spanning the full height of
       all the forms (feeds) it governs, and linking to the regulator's site. */
    .proc--regulator {
      background: var(--c-primary-tint);
      justify-content: center;
    }
    .proc--reglink {
      text-decoration: none;
      color: inherit;
      transition: background-color 0.15s ease;
    }
    .proc--reglink .proc__body {
      color: var(--c-primary);
      font-weight: 700;
      text-decoration: underline;
    }
    .proc--reglink:hover,
    .proc--reglink:focus-visible {
      background: var(--c-surface-alt);
    }
    @media (min-width: 48em) {
      .proc--regulator::before {
        content: "→";
        position: absolute;
        left: calc(var(--space-5) * -1 - 0.1em);
        top: 50%;
        transform: translateY(-50%);
        color: var(--c-border-strong);
        font-weight: 800;
      }
    }
    .proc {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
      padding: var(--space-3);
      background: var(--c-surface-alt);
      border-radius: var(--radius);
      position: relative;
    }
    .proc--pending {
      background: transparent;
      border: 1px dashed var(--c-border-strong);
    }
    .proc__step {
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--c-primary);
    }
    .proc--pending .proc__step {
      color: var(--c-text-muted);
    }
    .proc__body {
      font-size: 0.95rem;
      word-break: break-word;
    }
    /* Connector arrows between steps (decorative) */
    @media (min-width: 48em) {
      .proc + .proc::before {
        content: "→";
        position: absolute;
        left: calc(var(--space-3) * -1 - 0.4em);
        top: 50%;
        transform: translateY(-50%);
        color: var(--c-border-strong);
        font-weight: 800;
      }
    }
    .tribal-note,
    .reg-dir-h {
      max-width: 70ch;
    }
    .reg-dir-h {
      margin-top: var(--space-8);
      font-size: 1.2rem;
    }

    /* Legal grid */
    .legal-grid {
      list-style: none;
      display: grid;
      gap: var(--space-3);
      grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    }
    .legal-cell {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-areas: "icon label" "icon state" "cite cite";
      gap: 0 var(--space-3);
      padding: var(--space-4);
      border: 1px solid var(--c-border);
      border-radius: var(--radius);
      background: var(--c-surface);
    }
    .legal-cell--authorized {
      border-left: 4px solid var(--c-primary);
    }
    .legal-cell--not-authorized {
      background: var(--c-surface-alt);
    }
    .legal-cell--tribal-only,
    .legal-cell--limited {
      border-left: 4px solid var(--c-border-strong);
    }
    .legal-cell__status {
      grid-area: icon;
      font-weight: 800;
      font-size: 1.25rem;
      color: var(--c-primary);
    }
    .legal-cell--not-authorized .legal-cell__status {
      color: var(--c-text-muted);
    }
    .legal-cell__label {
      grid-area: label;
      font-weight: 700;
      color: var(--c-heading);
    }
    .legal-cell__state {
      grid-area: state;
      color: var(--c-text-muted);
      font-size: 0.95rem;
    }
    .legal-cell__cite {
      grid-area: cite;
      margin-top: var(--space-2);
      font-size: 0.8rem;
      word-break: break-word;
    }

    .fine-print {
      margin-top: var(--space-5);
      font-size: 0.85rem;
      color: var(--c-text-muted);
      max-width: 70ch;
    }

    /* Regulators */
    .reg-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    }
    .reg-list--sub {
      margin-top: var(--space-4);
    }
    .reg-item__name {
      margin: 0;
      font-weight: 700;
    }
    .reg-item__type,
    .reg-item__meta {
      margin: var(--space-1) 0 0;
      color: var(--c-text-muted);
      font-size: 0.9rem;
    }
    .reg-more {
      margin-top: var(--space-5);
    }
    .reg-more summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--c-primary);
      min-height: var(--target-min);
      display: flex;
      align-items: center;
    }

    .help-list {
      list-style: none;
      display: grid;
      gap: var(--space-3);
    }
    .coming {
      color: var(--c-text-muted);
    }

    /* Self-exclusion */
    .se-list {
      list-style: none;
      display: grid;
      gap: var(--space-4);
      margin-top: var(--space-5);
    }
    @media (min-width: 48em) {
      .se-list {
        grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
      }
    }
    .se-card {
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .se-card__head {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-2) var(--space-3);
    }
    .se-card__name {
      margin: 0;
      font-size: 1.1rem;
    }
    .se-badge {
      flex: none;
      font-size: 0.8rem;
      font-weight: 700;
      padding: 0.15rem 0.6rem;
      border-radius: 999px;
      background: var(--c-primary-tint);
      color: var(--c-primary);
      border: 1px solid var(--c-border);
    }
    .se-meta {
      margin: var(--space-4) 0 0;
      display: grid;
      gap: var(--space-3);
    }
    .se-meta__row {
      margin: 0;
    }
    .se-meta__row dt {
      font-weight: 700;
      font-size: 0.9rem;
    }
    .se-meta__row dd {
      margin: var(--space-1) 0 0;
    }
    .se-note {
      margin: var(--space-4) 0 0;
      padding: var(--space-3) var(--space-4);
      background: var(--c-primary-tint);
      border-radius: var(--radius-md, 8px);
      font-size: 0.95rem;
    }
    .se-more {
      margin-top: var(--space-5);
    }
    .se-more summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--c-primary);
      min-height: var(--target-min);
      display: flex;
      align-items: center;
    }
    .se-none-list {
      margin: var(--space-3) 0 0;
      padding-left: var(--space-5);
      display: grid;
      gap: var(--space-2);
    }

    /* History */
    .history summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--c-primary);
      min-height: var(--target-min);
      display: flex;
      align-items: center;
    }
    .history__body {
      margin-top: var(--space-4);
      max-width: 70ch;
    }
    .history__body :global(h2) {
      font-size: 1.3rem;
      margin-top: var(--space-6);
    }
    .history__body :global(h3) {
      font-size: 1.1rem;
    }
  </style>
</BaseLayout>
