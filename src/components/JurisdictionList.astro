---
import { jurisdictionsByName, linkFor } from "../data/map-jurisdictions";
---

<nav class="jurisdiction-list" aria-label="All states and territories">
  <ul>
    {
      jurisdictionsByName.map((j) => (
        <li>
          <a href={linkFor(j)}>
            <span class="jl-code" aria-hidden="true">{j.code}</span>
            <span>{j.name}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .jurisdiction-list ul {
    list-style: none;
    display: grid;
    gap: var(--space-2);
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
  }
  .jurisdiction-list a {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-height: var(--target-min);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    background: var(--c-surface);
    text-decoration: none;
    color: var(--c-text);
    font-weight: 600;
  }
  .jurisdiction-list a:hover {
    background: var(--c-primary-tint);
    border-color: var(--c-primary);
    color: var(--c-primary-hover);
  }
  .jl-code {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4rem;
    padding: var(--space-1) var(--space-2);
    background: var(--c-primary);
    color: #fff;
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.03em;
  }
</style>
