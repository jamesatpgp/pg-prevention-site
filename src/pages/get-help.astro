---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Get Help Now"
  description="Free, 24/7 help for gambling and gambling harm. Call or text the National Problem Gambling Helpline at 1-800-MY-RESET, or call or text 988 in a crisis."
>
  <section class="section get-help">
    <div class="container">
      <p class="eyebrow">Get help now</p>
      <h1>You can get help. It is free, and it is available any time.</h1>

      <div class="help-cards">
        <a class="help-card help-card--primary" href="tel:+18006973738">
          <img
            class="myreset-lockup"
            src="/brand/myreset-horizontal-color.png"
            width="640"
            height="162"
            alt="Call or text 1-800-MY-RESET, the National Problem Gambling Helpline"
          />
        </a>

        <a class="help-card" href="tel:988">
          <img
            class="lifeline-988-logo"
            src="/brand/988-horizontal-navy.png"
            width="640"
            height="124"
            alt="Call or text 988, the Suicide & Crisis Lifeline"
          />
        </a>
      </div>

      <p class="help-state">
        Looking for help near you?
        <a href="/find-your-state">Find resources in your state</a>.
      </p>
    </div>
  </section>

  <style>
    .eyebrow {
      margin: 0 0 var(--space-2);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--c-primary);
    }
    .help-cards {
      display: grid;
      gap: var(--space-5);
      margin-block: var(--space-6);
    }
    @media (min-width: 48em) {
      .help-cards {
        grid-template-columns: 1fr 1fr;
        align-items: start;
      }
    }
    .help-card {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-6);
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      text-decoration: none;
    }
    .help-card--primary {
      border-color: var(--c-primary);
      border-width: 2px;
      background: var(--c-primary-tint);
    }
    .myreset-lockup {
      display: block;
      width: 100%;
      max-width: 16rem;
      height: auto;
    }
    .lifeline-988-logo {
      display: block;
      width: 100%;
      max-width: 13rem;
      height: auto;
    }
    .help-state {
      font-size: 1.1rem;
    }
  </style>
</BaseLayout>
